                            <!-- PKCS#7 Input -->
                            <VBox spacing="8">
                                <Label text="PKCS#7 Data (Base64 or Hex):" style="-fx-font-weight: bold;"/>
                                <TextArea fx:id="verifyPkcs7Area" prefHeight="200" promptText="Paste PKCS#7 data here..." 
                                          style="-fx-font-family: 'Courier New', monospace;"/>
                            </VBox>
                            
                            <!-- Certificate (Optional) -->
