                                            style="-fx-font-size: 11px;"/>
                                </HBox>
                                <TextArea fx:id="generateCertArea" prefHeight="150" promptText="Paste certificate here or load from file..." 
                                          style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                            </VBox>
                            
                            <!-- Private Key -->
                            <VBox spacing="8">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Private Key (Required for Signed Data):" style="-fx-font-weight: bold;"/>
                                    <Button text="📁 Load File" onAction="#handleLoadKeyGenerate" 
                                            style="-fx-font-size: 11px;"/>
                                </HBox>
                                <TextArea fx:id="generatePrivateKeyArea" prefHeight="150" promptText="Paste private key here or load from file..." 
                                          style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                            </VBox>
                            
                            <!-- Type Selection -->
                            <VBox spacing="8">
                                <Label text="PKCS#7 Type:" style="-fx-font-weight: bold;"/>
                                <ComboBox fx:id="pkcs7TypeCombo" prefWidth="200"/>
                                <Label text="• Signed Data: Creates a digital signature (requires private key)" 
                                       style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                <Label text="• Enveloped Data: Encrypts data for recipient (only needs certificate)" 
                                       style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                            </VBox>
                            
                            <!-- Associated Data -->
                            <VBox spacing="8">
                                <Label text="Associated Data (Optional - for Signed Data only):" style="-fx-font-weight: bold;"/>
                                <Label text="Format: NumericOID=value (one per line). OIDs must be numbers like 1.2.3.4.5" 
                                       style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                <TextArea fx:id="associatedDataArea" prefHeight="80" promptText="Example (OIDs must be NUMERIC):&#10;1.2.3.4.5.6=MyCompany&#10;1.3.6.1.4.1.99999.1=ProjectX&#10;1.2.840.113549.1.9.2=Doc-2024-001" 
                                          style="-fx-font-family: 'Courier New', monospace;"/>
                            </VBox>
                            
                            <!-- Generate Button -->
                            <Button text="Generate PKCS#7" onAction="#handleGeneratePKCS7" 
                                    maxWidth="Infinity" style="-fx-font-size: 14px; -fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10px;"/>
                            
                            <!-- Result -->
                            <VBox spacing="8">
                                <Label text="Result:" style="-fx-font-weight: bold;"/>
                                <TextArea fx:id="generateResultArea" prefHeight="250" editable="false" 
                                          style="-fx-font-family: 'Courier New', monospace;" wrapText="true"/>
                            </VBox>
                            
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <!-- Verify Sub-Tab -->
