                    <Label text="Input Data" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                        <TextArea fx:id="asn1InputArea" wrapText="true" 
