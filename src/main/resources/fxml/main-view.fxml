                                <TextField fx:id="randomBytesField" promptText="Number of bytes" prefWidth="100" text="16" />
                            </HBox>
                            <ComboBox fx:id="randomFormatCombo" promptText="Output Format" prefWidth="260" />
                            <Button text="Generate Random" maxWidth="Infinity" styleClass="action-button" onAction="#handleGenerateRandom" />
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="CHECK DIGITS" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <ComboBox fx:id="checkDigitAlgorithmCombo" promptText="Algorithm" prefWidth="260" />
