                                <TextArea fx:id="verifyCertArea" prefHeight="150" promptText="Paste certificate here or load from file..." 
                                          style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                            </VBox>
                            
                            <!-- Private Key (For Enveloped) -->
                            <VBox spacing="8">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Private Key (Required for Enveloped Data):" style="-fx-font-weight: bold;"/>
                                    <Button text="📁 Load File" onAction="#handleLoadKeyVerify" 
                                            style="-fx-font-size: 11px;"/>
                                </HBox>
                                <TextArea fx:id="verifyPrivateKeyArea" prefHeight="150" promptText="Paste private key here or load from file..." 
                                          style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                            </VBox>
                            
                            <!-- Verify Button -->
                            <Button text="Verify / Decrypt PKCS#7" onAction="#handleVerifyDecryptPKCS7" 
                                    maxWidth="Infinity" style="-fx-font-size: 14px; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10px;"/>
                            
                            <!-- Result -->
                            <VBox spacing="8">
                                <Label text="Result:" style="-fx-font-weight: bold;"/>
                                <TextArea fx:id="verifyResultArea" prefHeight="300" editable="false" 
                                          style="-fx-font-family: 'Courier New', monospace;" wrapText="true"/>
                            </VBox>
                            
                        </VBox>
                    </ScrollPane>
                </Tab>
                
            </TabPane>
            
            <!-- History Tab Content (Own Layout) -->
            <VBox fx:id="historyCenterPane" spacing="15" style="-fx-padding: 20;" visible="false" managed="false">
                
                <!-- Filters and Search -->
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Category:" style="-fx-font-size: 13px;"/>
                    <ComboBox fx:id="historyCategoryFilter" prefWidth="150" style="-fx-font-size: 13px;"/>
                    
                    <Label text="Search:" style="-fx-font-size: 13px;" HBox.hgrow="NEVER"/>
