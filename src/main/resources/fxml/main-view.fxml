                            <!-- Data Input -->
                            <VBox spacing="8">
                                <Label text="Data to Sign/Encrypt:" style="-fx-font-weight: bold;"/>
                                <TextArea fx:id="generateDataArea" prefHeight="100" promptText="Enter data here..." 
                                          style="-fx-font-family: 'Courier New', monospace;"/>
                            </VBox>
                            
                            <!-- Certificate -->
                            <VBox spacing="8">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Certificate (PEM/DER):" style="-fx-font-weight: bold;"/>
