                            </HBox>
                            
                            <Label text="Output File (optional):" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <HBox spacing="5">
                                <TextField fx:id="fileOutputPathField" promptText="Output file path (optional)" HBox.hgrow="ALWAYS"/>
                                <Button text="Browse..." onAction="#handleBrowseOutputFile" minWidth="80" />
                            </HBox>
                            
                            <Label text="Conversion:" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="From:" minWidth="50"/>
                                <ComboBox fx:id="fileInputFormatCombo" promptText="Input Format" prefWidth="150" />
                                <Label text="To:" minWidth="30"/>
                                <ComboBox fx:id="fileOutputFormatCombo" promptText="Output Format" prefWidth="150" />
                            </HBox>
                            
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Text Encoding:" minWidth="100"/>
                                <ComboBox fx:id="fileEncodingCombo" promptText="Encoding" prefWidth="200" />
                            </HBox>
                            
                            <Button text="Convert / Analyze" maxWidth="Infinity" styleClass="action-button" onAction="#handleFileConvert" />
                            <Label text="Result:" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                            <TextArea fx:id="fileResultArea" prefHeight="150" wrapText="true" editable="false"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                            <Label text="ℹ️  All conversions: Hex, Base64, Text (UTF-8, EBCDIC, etc.) - Any to Any" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-style: italic;"/>
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="PADDING OPERATIONS" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <ComboBox fx:id="paddingStandardCombo" promptText="Padding Standard" prefWidth="260" />
                            <TextField fx:id="paddingBlockSizeField" promptText="Block Size (bytes)" text="16" />
                            <HBox spacing="5">
                                <Button text="Add Padding" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" onAction="#handleAddPadding" />
                                <Button text="Remove Padding" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" onAction="#handleRemovePadding" />
                            </HBox>
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="DATA DECIMALIZATION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <TextField fx:id="decimalizationTableField" promptText="Decimalization Table" text="0123456789012345" />
                            <TextField fx:id="decimalizationOffsetField" promptText="Offset" text="0000000000000000" />
                            <ComboBox fx:id="decimalizationOutputCombo" promptText="Output Type" prefWidth="260" />
                            <Button text="Decimalize" maxWidth="Infinity" styleClass="action-button" onAction="#handleDecimalize" />
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- Cipher Tab -->
            <Tab text="Cipher">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                        <Label text="SYMMETRIC ENCRYPTION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <ComboBox fx:id="symmetricAlgorithmCombo" promptText="Algorithm" prefWidth="260" />
                            <ComboBox fx:id="cipherModeCombo" promptText="Mode" prefWidth="260" />
                            <ComboBox fx:id="paddingCombo" promptText="Padding" prefWidth="260" />
                            <TextField fx:id="symmetricKeyField" promptText="Key (Hex)" />
                            <TextField fx:id="ivField" promptText="IV (Hex) - if required" />
                            
                            <HBox spacing="5">
                                <Button text="Encrypt" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" onAction="#handleSymmetricEncrypt" />
                                <Button text="Decrypt" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" onAction="#handleSymmetricDecrypt" />
                            </HBox>
                            <HBox spacing="5">
                                <Button text="Encrypt File..." HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="secondary-button" onAction="#handleSymmetricEncryptFile" />
                                <Button text="Decrypt File..." HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="secondary-button" onAction="#handleSymmetricDecryptFile" />
                            </HBox>
                            <Button text="Analyze Encrypted File..." maxWidth="Infinity" styleClass="secondary-button" onAction="#handleAnalyzeEncryptedFile" />
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="ASYMMETRIC ENCRYPTION (RSA)" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <Label text="RSA Padding:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <ComboBox fx:id="rsaPaddingCombo" promptText="Padding Scheme" prefWidth="260" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="Load keys (PEM format):" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <Button text="Load Public Key (PEM)..." maxWidth="Infinity" styleClass="action-button" onAction="#handleLoadPublicKey" />
                            <Button text="Load Private Key (PEM)..." maxWidth="Infinity" styleClass="action-button" onAction="#handleLoadPrivateKey" />
                            <Label fx:id="asymmetricKeyStatusLabel" text="No keys loaded" style="-fx-font-size: 10px; -fx-text-fill: #666; -fx-padding: 5 0 0 0;" />
                            
                            <HBox spacing="5">
                                <Button text="Encrypt" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" onAction="#handleAsymmetricEncrypt" />
                                <Button text="Decrypt" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" onAction="#handleAsymmetricDecrypt" />
                            </HBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- Authentication Tab -->
            <Tab text="Authentication">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                        
                        <Label text="DIGITAL SIGNATURES" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <Label text="Signature Algorithm:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <ComboBox fx:id="signatureAlgorithmCombo" promptText="Select signature algorithm" prefWidth="260" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="Load keys (PEM format):" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <Button text="Load Private Key (PEM) - for signing..." maxWidth="Infinity" styleClass="action-button" onAction="#handleLoadSignPrivateKey" />
                            <Button text="Load Public Key (PEM) - for verification..." maxWidth="Infinity" styleClass="action-button" onAction="#handleLoadSignPublicKey" />
                            <Label fx:id="signatureKeyStatusLabel" text="No keys loaded" style="-fx-font-size: 10px; -fx-text-fill: #666; -fx-padding: 5 0 0 0;" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Button text="Sign" maxWidth="Infinity" styleClass="action-button" onAction="#handleSign" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="Verification:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <Label text="Signature (paste here for verification):" style="-fx-font-size: 10px;"/>
                            <TextField fx:id="signatureVerifyField" promptText="Paste signature here (format: toolbar Output Format)" />
                            
                            <Button text="Verify Signature" maxWidth="Infinity" styleClass="action-button" onAction="#handleVerify" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="ℹ️  Sign: data in Input → signature in Output" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-style: italic;"/>
                            <Label text="ℹ️  Verify: signature above, data in Input → result popup" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-style: italic;"/>
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="MESSAGE AUTHENTICATION CODES (MAC)" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <Label text="MAC Algorithm:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <ComboBox fx:id="authMacAlgorithmCombo" promptText="Select MAC algorithm" maxWidth="Infinity" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="MAC Key (Hex):" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <TextField fx:id="authMacKeyField" promptText="Enter MAC key in hexadecimal" />
                            <Label fx:id="authMacKeyInfoLabel" text="Key size depends on algorithm" 
                                   style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <VBox spacing="8" style="-fx-padding: 5 0 5 0;">
                                <Label text="Key Components (Optional - for ANSI X9.19):" 
                                       style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                <HBox spacing="10">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="K:" style="-fx-font-size: 10px; -fx-font-weight: bold;" />
                                        <TextField fx:id="authMacKeyK" promptText="First 8 bytes (hex)" />
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="K':" style="-fx-font-size: 10px; -fx-font-weight: bold;" />
                                        <TextField fx:id="authMacKeyKPrime" promptText="Second 8 bytes (hex)" />
                                    </VBox>
                                </HBox>
                                <Label text="Leave empty to use MAC Key field above. If filled, K||K' will be concatenated automatically." 
                                       style="-fx-font-size: 9px; -fx-text-fill: #666; -fx-wrap-text: true; -fx-padding: 0 0 5 0;"/>
                            </VBox>
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="Truncation:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <ComboBox fx:id="authMacTruncationCombo" prefWidth="100" />
                                <Label text="bytes (0 = full MAC)" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                            </HBox>
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Button text="Generate MAC" maxWidth="Infinity" styleClass="action-button" onAction="#handleGenerateMAC" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="Verification:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <Label text="MAC value (paste here for verification):" style="-fx-font-size: 10px;"/>
                            <TextField fx:id="authMacVerifyField" promptText="Paste MAC here (format: toolbar Output Format)" />
                            
                            <Button text="Verify MAC" maxWidth="Infinity" styleClass="action-button" onAction="#handleVerifyMAC" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="ℹ️  Generate: data in Input → MAC in Output" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-style: italic;"/>
                            <Label text="ℹ️  Verify: MAC above, data in Input → result popup" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-style: italic;"/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- Keys Tab -->
            <Tab text="Keys" closable="false"/>

            
            <!-- Payments Tab -->
            <Tab text="Payments" closable="false"/>
            
            <!-- CMS Tab -->
            <Tab text="CMS" closable="false"/>
            
            <!-- EMV Tab -->
            <Tab text="EMV">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                        
                        <!-- SESSION KEY DERIVATION -->
                        <Label text="SESSION KEY DERIVATION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <TextField fx:id="imkField" promptText="Issuer Master Key (32 hex chars)" />
                            <TextField fx:id="panFieldSession" promptText="PAN (Primary Account Number)" />
                            <TextField fx:id="panSeqFieldSession" promptText="PAN Sequence (00-99)" text="00" />
                            <TextField fx:id="atcField" promptText="ATC - Application Transaction Counter (4 hex chars, optional)" />
                            <Button text="Derive Session Keys" onAction="#handleDeriveSessionKey" maxWidth="Infinity" styleClass="action-button" />
                            <TextArea fx:id="sessionKeyResultArea" prefHeight="180" editable="false" wrapText="true"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                      promptText="Session keys will appear here..."/>
                        </VBox>
                        
                        <Separator />
                        
                        <!-- ARQC GENERATION -->
                        <Label text="ARQC GENERATION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <TextField fx:id="skARQCField" promptText="Session Key (32 hex chars)" />
                            <TextField fx:id="amountField" promptText="Amount (12 hex chars, e.g., 000000012345 = 123.45)" />
                            <HBox spacing="5">
                                <TextField fx:id="currencyField" promptText="Currency (0978=EUR)" text="0978" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="countryField" promptText="Country (0724=ESP)" text="0724" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <HBox spacing="5">
                                <TextField fx:id="atcARQCField" promptText="ATC (4 hex)" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="tvrField" promptText="TVR (10 hex)" text="0000000000" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <HBox spacing="5">
                                <TextField fx:id="txDateField" promptText="Date YYMMDD (6 hex)" text="251207" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="txTypeField" promptText="Type (2 hex)" text="00" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="unField" promptText="UN (8 hex)" text="12345678" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <HBox spacing="5">
                                <Button text="Generate ARQC" onAction="#handleGenerateARQC" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" />
                                <Button text="Verify ARQC" onAction="#handleVerifyARQC" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" />
                            </HBox>
                            <TextArea fx:id="arqcResultArea" prefHeight="200" editable="false" wrapText="true"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                      promptText="ARQC results will appear here..."/>
                        </VBox>
                        
                        <Separator />
                        
                        <!-- ARPC GENERATION -->
                        <Label text="ARPC GENERATION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <TextField fx:id="skARPCField" promptText="Session Key (32 hex chars)" />
                            <TextField fx:id="arqcField" promptText="ARQC from card (16 hex chars)" />
                            <TextField fx:id="arcField" promptText="ARC - Authorization Response Code (4 hex, e.g., 3030=Approved)" />
                            <TextField fx:id="csuField" promptText="CSU - Card Status Update (8 hex, optional for Method 2)" />
                            <ComboBox fx:id="arpcMethodCombo" prefWidth="260" />
                            <Button text="Generate ARPC" onAction="#handleGenerateARPC" maxWidth="Infinity" styleClass="action-button" />
                            <TextArea fx:id="arpcResultArea" prefHeight="150" editable="false" wrapText="true"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                      promptText="ARPC will appear here..."/>
                        </VBox>
                        
                        <Separator />
                        
                        <!-- TRACK 2 OPERATIONS -->
                        <Label text="TRACK 2 DATA" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <Label text="Encode:" style="-fx-font-size: 11px; -fx-font-style: italic;" />
                            <TextField fx:id="panTrack2Field" promptText="PAN (Primary Account Number)" />
                            <HBox spacing="5">
                                <TextField fx:id="expiryTrack2Field" promptText="Expiry YYMM" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="serviceCodeFieldTrack2" promptText="Service Code (3 digits)" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <TextField fx:id="discretionaryDataField" promptText="Discretionary Data (optional)" />
                            <Button text="Encode Track 2" onAction="#handleEncodeTrack2" maxWidth="Infinity" styleClass="action-button" />
                            
                            <Label text="Decode:" style="-fx-font-size: 11px; -fx-font-style: italic; -fx-padding: 10 0 0 0;" />
                            <TextField fx:id="track2InputField" promptText="Track 2 Data (hex)" />
                            <Button text="Decode Track 2" onAction="#handleDecodeTrack2" maxWidth="Infinity" styleClass="action-button" />
                            
                            <TextArea fx:id="track2ResultArea" prefHeight="130" editable="false" wrapText="true"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                      promptText="Track 2 results will appear here..."/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- Development Tab -->
            
            <!-- History Tab -->
            <Tab text="History">
                <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
                    <Label text="📊 Operation History" style="-fx-font-weight: bold; -fx-font-size: 18px;"/>
                    <Label text="View complete history in the" style="-fx-font-size: 13px;"/>
                    <Label text="main area →" style="-fx-font-size: 13px; -fx-text-fill: gray;"/>
                    <Separator prefWidth="200"/>
                    <Label text="All operations are automatically" style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
                    <Label text="saved and displayed" style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
                    <Label text="in a searchable table" style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
                </VBox>
            </Tab>
            
            <!-- ASN.1 Parser Tab -->
            <Tab text="ASN.1">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="12" style="-fx-padding: 15;">
                        
                        <Label text="ASN.1 PARSER" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Label text="Parse and analyze DER/BER encoded ASN.1 structures" 
                               style="-fx-font-size: 10px; -fx-text-fill: #666; -fx-wrap-text: true;"/>
                        
                        <Separator />
                        
                        <!-- Input Format -->
                        <VBox spacing="5">
                            <Label text="Input Format:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <ComboBox fx:id="asn1InputFormatCombo" maxWidth="Infinity" />
                        </VBox>
                        
                        <!-- Common Types -->
                        <VBox spacing="5">
                            <Label text="Example Types:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <ComboBox fx:id="asn1TypeCombo" maxWidth="Infinity" />
                        </VBox>
                        
                        <Separator />
                        
                        <!-- Action Buttons -->
                        <VBox spacing="8">
                            <Button text="Parse ASN.1" maxWidth="Infinity" 
                                    styleClass="action-button" onAction="#handleParseASN1" />
                            <Button text="Load File..." maxWidth="Infinity" 
                                    styleClass="action-button" onAction="#handleLoadASN1File" />
                            <Button text="Load Example" maxWidth="Infinity" 
                                    styleClass="action-button" onAction="#handleLoadASN1Example" />
                            <Button text="Export Tree..." maxWidth="Infinity" 
                                    styleClass="action-button" onAction="#handleExportASN1Tree" />
                            <Button text="Clear" maxWidth="Infinity" 
                                    styleClass="action-button" onAction="#handleClearASN1" />
                        </VBox>
                        
                        <Separator />
                        
                        <!-- Info -->
                        <VBox spacing="3">
                            <Label text="ℹ️  Supported formats:" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                            <Label text="  • X.509 Certificates" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                            <Label text="  • RSA/EC Keys" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                            <Label text="  • CSRs &amp; PKCS#7/CMS" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                            <Label text="  • Custom structures" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                        </VBox>
                        
                        <VBox spacing="3" style="-fx-padding: 10 0 0 0;">
                            <Label text="💡 Quick Start:" 
                                   style="-fx-text-fill: #3498db; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                            <Label text="  1. Select example type" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                            <Label text="  2. Click 'Load Example'" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                            <Label text="  3. Auto-parse → See tree!" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                        </VBox>
                        
                    </VBox>
                </ScrollPane>
            </Tab>
            
            
        </TabPane>
    </left>
    
    <!-- Status Bar -->
    <bottom>
        <HBox spacing="10" style="-fx-background-color: #f0f0f0; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="5" right="5" bottom="5" left="5" /></padding>
            <Label fx:id="statusLabel" text="Ready" HBox.hgrow="ALWAYS" />
            <Label text="Java 21 | JavaFX 21 | BouncyCastle" style="-fx-text-fill: #666;" />
        </HBox>
    </bottom>
    
</BorderPane>
