                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="Service Code:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="serviceCodeField" promptText="3 digits (e.g., 101)" prefWidth="200" style="-fx-font-size: 14px;"/>
