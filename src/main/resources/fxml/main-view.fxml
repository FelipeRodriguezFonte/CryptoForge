                        </VBox>
                    </ScrollPane>
                </Tab>
            </TabPane>

            
            <!-- CMS Tab Content (TabPane with sub-tabs) -->
            <TabPane fx:id="cmsCenterPane" tabClosingPolicy="UNAVAILABLE" visible="false" managed="false">
                
