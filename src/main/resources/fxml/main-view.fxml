<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.cryptocarver.ui.MainController">
    
    <!-- Menu Bar -->
    <top>
        <VBox>
            <MenuBar styleClass="main-menu-bar">
                <Menu text="File">
                    <MenuItem text="New" accelerator="Ctrl+N" />
                    <MenuItem text="Open..." accelerator="Ctrl+O" />
                    <MenuItem text="Save..." accelerator="Ctrl+S" />
                    <SeparatorMenuItem />
                    <MenuItem text="Exit" onAction="#handleExit" accelerator="Ctrl+Q" />
                </Menu>
                
                <Menu text="Edit">
                    <MenuItem text="Clear Input" onAction="#handleClearInput" accelerator="Ctrl+Shift+I" />
                    <MenuItem text="Clear Output" onAction="#handleClearOutput" accelerator="Ctrl+Shift+O" />
                    <MenuItem text="Copy Output" onAction="#handleCopyOutput" accelerator="Ctrl+C" />
                </Menu>
                
                <Menu text="View">
                    <Menu text="Theme">
                        <RadioMenuItem fx:id="themeLightItem" text="Light (Default)" selected="true" onAction="#handleThemeLight"/>
                        <RadioMenuItem fx:id="themeDarkItem" text="Dark" onAction="#handleThemeDark"/>
                        <RadioMenuItem fx:id="themeHighContrastItem" text="High Contrast" onAction="#handleThemeHighContrast"/>
                        <RadioMenuItem fx:id="themeSolarizedItem" text="Solarized Dark" onAction="#handleThemeSolarized"/>
                        <RadioMenuItem fx:id="themeDraculaItem" text="Dracula" onAction="#handleThemeDracula"/>
                    </Menu>
                    <Menu text="Font Size">
                        <RadioMenuItem fx:id="fontSmallItem" text="Small (11px)" onAction="#handleFontSmall">
                            <toggleGroup>
                                <ToggleGroup fx:id="fontSizeToggleGroup"/>
                            </toggleGroup>
                        </RadioMenuItem>
                        <RadioMenuItem fx:id="fontMediumItem" text="Medium (13px)" selected="true" onAction="#handleFontMedium" toggleGroup="$fontSizeToggleGroup"/>
                        <RadioMenuItem fx:id="fontLargeItem" text="Large (15px)" onAction="#handleFontLarge" toggleGroup="$fontSizeToggleGroup"/>
                        <RadioMenuItem fx:id="fontExtraLargeItem" text="Extra Large (18px)" onAction="#handleFontExtraLarge" toggleGroup="$fontSizeToggleGroup"/>
                    </Menu>
                    <SeparatorMenuItem/>
                    <MenuItem text="Reset to Defaults" onAction="#handleResetView"/>
                </Menu>
                
                <Menu text="Tools">
                    <MenuItem text="KeyStore Manager..." />
                    <MenuItem text="Import Key..." />
                    <MenuItem text="Export Key..." />
                    <SeparatorMenuItem />
                    <MenuItem text="Preferences..." />
                </Menu>
                
                <Menu text="Help">
                    <MenuItem text="Documentation" />
                    <MenuItem text="Cipher Reference" />
                    <SeparatorMenuItem />
                    <MenuItem text="About" onAction="#handleAbout" />
                </Menu>
            </MenuBar>
            
            <!-- Toolbar -->
            <ToolBar>
                <Button text="Clear" onAction="#handleClearInput" />
                <Separator orientation="VERTICAL" />
                <Label text="Input Format:" />
                <ComboBox fx:id="inputFormatCombo" prefWidth="120" />
                <Separator orientation="VERTICAL" />
                <Label text="Output Format:" />
                <ComboBox fx:id="outputFormatCombo" prefWidth="120" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Copy Output" onAction="#handleCopyOutput" />
            </ToolBar>
        </VBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <StackPane fx:id="centerStack">
            
            <!-- Generic/Cipher Content (Input/Output) -->
            <SplitPane fx:id="genericCenterPane" dividerPositions="0.7" orientation="VERTICAL">
                
                <!-- Input Section -->
                <VBox spacing="5">
                    <padding>
                        <Insets top="10" right="10" bottom="5" left="10" />
                    </padding>
                    <Label text="Input Data" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <TextArea fx:id="inputArea" VBox.vgrow="ALWAYS" wrapText="true" />
                </VBox>
                
                <!-- Output Section -->
                <VBox spacing="5">
                    <padding>
                        <Insets top="5" right="10" bottom="10" left="10" />
                    </padding>
                    <Label text="Output" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <TextArea fx:id="outputArea" VBox.vgrow="ALWAYS" wrapText="true" editable="false" />
                </VBox>
                
            </SplitPane>
            
            <!-- Keys Tab Content (Own Layout) -->
            <!-- Keys Tab Content (TabPane for different key types) -->
            <TabPane fx:id="keysCenterPane" tabClosingPolicy="UNAVAILABLE" visible="false" managed="false">
                
                <!-- Symmetric Keys Tab - REDESIGNED WITH ACCORDION -->
                <Tab text="Symmetric Keys" closable="false">
                    <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">
                        <VBox spacing="5" style="-fx-padding: 8;" prefWidth="1200">
                            
                            <Accordion>
                                <panes>
                                    <!-- KEY GENERATION -->
                                    <TitledPane text="🔑 Key Generation" expanded="true">
                                    <VBox spacing="4" style="-fx-padding: 6;">
                                        <GridPane hgap="6" vgap="4">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="70" prefWidth="70"/>
                                                <ColumnConstraints minWidth="180" prefWidth="220"/>
                                                <ColumnConstraints hgrow="ALWAYS"/>
                                            </columnConstraints>
                                            
                                            <Label text="Type:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="keyTypeCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200" style="-fx-font-size: 11px;"/>
                                            
                                            <CheckBox fx:id="forceOddParityCheck" text="Force Odd Parity (DES/3DES)" 
                                                      selected="true" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-size: 10px;"/>
                                        </GridPane>
                                        
                                        <Button text="Generate Key" onAction="#handleGenerateKey" 
                                                styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                        
                                        <!-- LARGE result area to fill space -->
                                        <TextArea fx:id="generatedKeyField" prefHeight="280" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                  promptText="Generated key will appear here..."/>
                                    </VBox>
                                </TitledPane>
                                
                                <!-- KEY VALIDATION -->
                                <TitledPane text="✓ Validation &amp; KCV">
                                    <VBox spacing="4" style="-fx-padding: 6;">
                                        <!-- Input como TextField (1 línea) -->
                                        <TextField fx:id="keyInputField" promptText="Enter key in hexadecimal..."
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                                        
                                        <Button text="Validate &amp; Calculate KCVs" onAction="#handleValidateKey" 
                                                styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>
                                        
                                        <!-- LARGE result area -->
                                        <TextArea fx:id="validationResultArea" prefHeight="260" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                  promptText="Validation results will appear here..."
                                                  managed="false" visible="false"/>
                                    </VBox>
                                </TitledPane>
                                
                                <!-- KEY SHARING -->
                                <TitledPane text="🔀 Key Sharing (XOR Split/Combine)">
                                    <VBox spacing="6" style="-fx-padding: 8;">
                                        <TabPane tabClosingPolicy="UNAVAILABLE">
                                            <Tab text="Split Key">
                                                <VBox spacing="6" style="-fx-padding: 8;">
                                                    <TextArea fx:id="keyToSplitField" prefHeight="35" wrapText="true"
                                                              style="-fx-font-family: 'Courier New', monospace;"
                                                              promptText="Enter key to split..."/>
                                                    
                                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                                        <Label text="Parts:"/>
                                                        <ComboBox fx:id="numComponentsCombo" prefWidth="80"/>
                                                        <Button text="Split Key" onAction="#handleSplitKey" 
                                                                styleClass="action-button"/>
                                                    </HBox>
                                                </VBox>
                                            </Tab>
                                            
                                            <Tab text="Combine Components">
                                                <VBox spacing="6" style="-fx-padding: 8;">
                                                    <GridPane hgap="8" vgap="4">
                                                        <columnConstraints>
                                                            <ColumnConstraints minWidth="90" prefWidth="90"/>
                                                            <ColumnConstraints hgrow="ALWAYS"/>
                                                        </columnConstraints>
                                                        
                                                        <Label text="Component 1:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                                        <TextField fx:id="component1Field" promptText="Required" 
                                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                                        
                                                        <Label text="Component 2:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                                        <TextField fx:id="component2Field" promptText="Required"
                                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                                  GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                                        
                                                        <Label text="Component 3:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                                        <TextField fx:id="component3Field" promptText="Optional"
                                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                                        
                                                        <Label text="Component 4:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                                        <TextField fx:id="component4Field" promptText="Optional"
                                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                                  GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                                        
                                                        <Label text="Component 5:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                                        <TextField fx:id="component5Field" promptText="Optional"
                                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                                  GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                                    </GridPane>
                                                    
                                                    <Button text="Combine Components" onAction="#handleCombineComponents" 
                                                            styleClass="action-button" maxWidth="200"/>
                                                </VBox>
                                            </Tab>
                                        </TabPane>
                                        
                                        <TextArea fx:id="componentResultsArea" prefHeight="100" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace;"
                                                  promptText="Results will appear here..."
                                                  managed="false" visible="false"/>
                                    </VBox>
                                </TitledPane>
                                
                                <!-- KEY DERIVATION -->
                                <TitledPane text="🔐 Key Derivation (KDF)">
                                    <VBox spacing="4" style="-fx-padding: 6;">
                                        <!-- Compact controls in GridPane -->
                                        <GridPane hgap="6" vgap="4">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="90" prefWidth="90"/>
                                                <ColumnConstraints minWidth="140" prefWidth="160"/>
                                                <ColumnConstraints minWidth="70" prefWidth="75"/>
                                                <ColumnConstraints hgrow="ALWAYS"/>
                                            </columnConstraints>
                                            
                                            <Label text="Algorithm:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="kdfAlgorithmCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" 
                                                     GridPane.columnSpan="3" prefWidth="180" style="-fx-font-size: 11px;"/>
                                            
                                            <Label text="Input Format:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="kdfInputFormatCombo" GridPane.rowIndex="1" GridPane.columnIndex="1" 
                                                     prefWidth="90" style="-fx-font-size: 11px;"/>
                                            
                                            <Label text="Iterations:" GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="kdfIterationsField" text="10000" GridPane.rowIndex="1" GridPane.columnIndex="3" 
                                                      prefWidth="60" style="-fx-font-size: 11px;"/>
                                            
                                            <Label text="Output:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                            <HBox spacing="3" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                                <TextField fx:id="kdfOutputLengthField" text="32" prefWidth="50" style="-fx-font-size: 11px;"/>
                                                <Label text="bytes" style="-fx-font-size: 10px;"/>
                                            </HBox>
                                        </GridPane>
                                        
                                        <!-- Input material - small -->
                                        <TextField fx:id="kdfInputField" promptText="Input key material..."
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                                        
                                        <!-- Salt and Info in HBox -->
                                        <HBox spacing="4">
                                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                                <HBox spacing="3" alignment="CENTER_LEFT">
                                                    <Label text="Salt:" style="-fx-font-size: 10px;"/>
                                                    <ComboBox fx:id="kdfSaltFormatCombo" prefWidth="70" style="-fx-font-size: 10px;"/>
                                                </HBox>
                                                <TextField fx:id="kdfSaltField" promptText="Optional" style="-fx-font-size: 10px;"/>
                                            </VBox>
                                            
                                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                                <HBox spacing="3" alignment="CENTER_LEFT">
                                                    <Label text="Info:" style="-fx-font-size: 10px;"/>
                                                    <ComboBox fx:id="kdfInfoFormatCombo" prefWidth="70" style="-fx-font-size: 10px;"/>
                                                </HBox>
                                                <TextField fx:id="kdfInfoField" promptText="HKDF only" style="-fx-font-size: 10px;"/>
                                            </VBox>
                                        </HBox>
                                        
                                        <Button text="Derive Key" onAction="#handleDeriveKey" 
                                                styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                        
                                        <!-- LARGE result area to fill available space -->
                                        <TextArea fx:id="kdfResultArea" prefHeight="250" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                  promptText="Derived key will appear here..."
                                                  managed="false" visible="false"/>
                                    </VBox>
                                </TitledPane>
                                </panes>
                            </Accordion>
                            
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <!-- RSA Tab -->
                <Tab text="RSA" closable="false">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="RSA Key Generation" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Key Size:"/>
                                <ComboBox fx:id="rsaKeySizeCombo" prefWidth="120"/>
                                <Button text="Generate RSA Key Pair" onAction="#handleGenerateRSA" 
                                        style="-fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white;"/>
                            </HBox>
                            
                            <Separator/>
                            
                            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS" orientation="HORIZONTAL">
                                <VBox spacing="5">
                                    <Label text="Public Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="rsaPublicKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Private Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="rsaPrivateKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                            </SplitPane>
                            
                            <Label text="⚠️  RSA keys > 4096 bits may take several seconds to generate" 
                                   style="-fx-text-fill: #e67e22; -fx-font-style: italic;"/>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <!-- DSA Tab -->
                <Tab text="DSA" closable="false">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="DSA Key Generation" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Key Size (L/N):"/>
                                <ComboBox fx:id="dsaKeySizeCombo" prefWidth="120"/>
                                <Button text="Generate DSA Key Pair" onAction="#handleGenerateDSA"
                                        style="-fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white;"/>
                            </HBox>
                            
                            <Separator/>
                            
                            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS" orientation="HORIZONTAL">
                                <VBox spacing="5">
                                    <Label text="Public Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="dsaPublicKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Private Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="dsaPrivateKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                            </SplitPane>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <!-- ECDSA F(p) Tab -->
                <Tab text="ECDSA F(p)" closable="false">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="ECDSA F(p) - Elliptic Curve over Prime Field" 
                                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Named Curve:"/>
                                <ComboBox fx:id="ecdsaFpCurveCombo" prefWidth="150"/>
                                <Button text="Generate ECDSA F(p) Key Pair" onAction="#handleGenerateECDSAFp"
                                        style="-fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white;"/>
                            </HBox>
                            
                            <Separator/>
                            
                            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS" orientation="HORIZONTAL">
                                <VBox spacing="5">
                                    <Label text="Public Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="ecdsaFpPublicKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Private Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="ecdsaFpPrivateKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                            </SplitPane>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <!-- Ed25519 Tab -->
                <Tab text="Ed25519" closable="false">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="Ed25519 - Modern Elliptic Curve Signature" 
                                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Ed25519 (255-bit curve, fast signatures)"/>
                                <Button text="Generate Ed25519 Key Pair" onAction="#handleGenerateEd25519"
                                        style="-fx-font-weight: bold; -fx-background-color: #9b59b6; -fx-text-fill: white;"/>
                            </HBox>
                            
                            <Separator/>
                            
                            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS" orientation="HORIZONTAL">
                                <VBox spacing="5">
                                    <Label text="Public Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="ed25519PublicKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Private Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="ed25519PrivateKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                            </SplitPane>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                
                <!-- Certificates Tab -->
                <Tab text="Certificates" closable="false">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="X.509 Self-Signed Certificate Generator" 
                                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            
                            <GridPane hgap="10" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="30"/>
                                    <ColumnConstraints percentWidth="70"/>
                                </columnConstraints>
                                
                                <Label text="Common Name (CN):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="certCNField" promptText="localhost" 
                                          GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                
                                <Label text="Organization (O):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <TextField fx:id="certOrgField" promptText="Crypto Org" 
                                          GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                
                                <Label text="Organizational Unit (OU):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <TextField fx:id="certOUField" promptText="Cybersecurity" 
                                          GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                
                                <Label text="Locality (L):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <TextField fx:id="certLocalityField" promptText="Madrid" 
                                          GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                
                                <Label text="State (ST):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                <TextField fx:id="certStateField" promptText="Madrid" 
                                          GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                
                                <Label text="Country (C):" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                <TextField fx:id="certCountryField" promptText="ES" maxWidth="60"
                                          GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                                
                                <Label text="Email (optional):" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                                <TextField fx:id="certEmailField" promptText="user@example.com" 
                                          GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                                
                                <Separator GridPane.rowIndex="7" GridPane.columnSpan="2"/>
                                
                                <Label text="Validity (days):" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                                <TextField fx:id="certValidityField" text="365" maxWidth="100"
                                          GridPane.rowIndex="8" GridPane.columnIndex="1"/>
                                
                                <Label text="Key Type:" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="certKeyTypeCombo" prefWidth="150"
                                         GridPane.rowIndex="9" GridPane.columnIndex="1"/>
                                
                                <Label text="Signature Algorithm:" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="certSignAlgoCombo" prefWidth="200"
                                         GridPane.rowIndex="10" GridPane.columnIndex="1"/>
                            </GridPane>
                            
                            <Button text="Generate Self-Signed Certificate" onAction="#handleGenerateCertificate"
                                    style="-fx-font-weight: bold; -fx-background-color: #e74c3c; -fx-text-fill: white;"
                                    prefWidth="300"/>
                            
                            <Separator/>
                            
                            <Label text="Certificate Output (PEM + Private Key)" style="-fx-font-weight: bold;"/>
                            <TextArea fx:id="certOutputArea" wrapText="true" editable="false"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"
                                      VBox.vgrow="ALWAYS" prefHeight="400"/>
                                      
                            <Label text="⚠️  WARNING: Self-signed certificates are NOT suitable for production use" 
                                   style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <!-- TR-31 Key Block Tab -->
                <Tab text="TR-31 Key Block" closable="false">
                    <HBox spacing="0">
                        <!-- LEFT PANEL: Controls -->
                        <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" 
                                    prefWidth="500" minWidth="450" HBox.hgrow="NEVER">
