                    <Button text="↻ Refresh" onAction="#handleHistoryRefresh" 
                            style="-fx-font-size: 13px;" prefWidth="90"/>
                </HBox>
                
                <!-- History Table -->
                <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="timestampColumn" text="Timestamp" prefWidth="150"/>
                        <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120"/>
                        <TableColumn fx:id="operationColumn" text="Operation" prefWidth="250"/>
                        <TableColumn fx:id="inputColumn" text="Input" prefWidth="300"/>
                        <TableColumn fx:id="outputColumn" text="Output" prefWidth="250"/>
