                            <ComboBox fx:id="hashAlgorithmCombo" promptText="Hash Algorithm" prefWidth="260" />
                            <Button text="Calculate Hash" maxWidth="Infinity" styleClass="action-button" onAction="#handleCalculateHash" />
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="ENCODING / CONVERSION" style="-fx-font-weight: bold;" />
