                                <Label text="• ISO 3: With random padding for security" style="-fx-font-size: 10px;"/>
                                <Label text="• ISO 4: Modern AES-based format (16-byte block)" style="-fx-font-size: 10px;"/>
                                <Label text="• IBM 3624: Classic PIN derivation method" style="-fx-font-size: 10px;"/>
                                <Label text="• VISA PVV: PIN verification at issuer" style="-fx-font-size: 10px;"/>
