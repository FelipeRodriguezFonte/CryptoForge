                            <TextField fx:id="modOperandBField" promptText="Operand B (hex)" style="-fx-font-family: 'Courier New', monospace;"/>
                            <TextField fx:id="modModulusField" promptText="Modulus (hex)" style="-fx-font-family: 'Courier New', monospace;"/>
                            <Button text="Calculate" maxWidth="Infinity" styleClass="action-button" onAction="#handleModularCalculate" />
                            <Label text="Result:" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                            <TextArea fx:id="modResultArea" prefHeight="120" wrapText="true" editable="false"
