                                              promptText="Paste TR-31 key block here..."/>
                                    
                                    <Label text="Expected Key Length (optional):" style="-fx-font-size: 13px;"/>
                                    <TextField fx:id="tr31KeyLengthField" promptText="Key length in bytes (e.g., 16, 24, 32)"
                                               style="-fx-font-size: 12px;" disable="true"/>
                                    
                                    <HBox spacing="10">
                                        <Button text="Unwrap Key (Import)" onAction="#handleTR31Import" 
                                                styleClass="button-primary" HBox.hgrow="ALWAYS" style="-fx-font-size: 13px;"/>
                                        <Button text="Parse Header Only" onAction="#handleTR31ParseHeader" 
                                                styleClass="button-secondary" HBox.hgrow="ALWAYS" style="-fx-font-size: 13px;"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </ScrollPane>
                        
                        <!-- RIGHT PANEL: Results -->
                        <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 20; -fx-background-color: #f8f9fa;">
                            <Label text="TR-31 Export Results" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <TextArea fx:id="tr31ExportResultArea" wrapText="true" editable="false"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                      VBox.vgrow="ALWAYS" prefHeight="300"/>
                            
                            <Separator style="-fx-padding: 10 0;"/>
                            
                            <Label text="TR-31 Import Results" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <TextArea fx:id="tr31ImportResultArea" wrapText="true" editable="false"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                      VBox.vgrow="ALWAYS" prefHeight="300"/>
                        </VBox>
                    </HBox>
                </Tab>
                
            </TabPane>
            
            
            <!-- Payments Tab Content (Own Layout) -->
            <ScrollPane fx:id="paymentsCenterPane" fitToWidth="true" vbarPolicy="AS_NEEDED" visible="false" managed="false">
                <VBox spacing="25" style="-fx-padding: 30;">
                    
                    <!-- PIN BLOCKS -->
                    <VBox spacing="15">
                        <Label text="PIN BLOCKS" style="-fx-font-weight: bold; -fx-font-size: 18px;"/>
                        
                        <Label text="Encode PIN Block:" style="-fx-font-style: italic; -fx-font-size: 14px;"/>
                        <VBox spacing="12">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="PIN:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="pinField" promptText="Enter 4-12 digits" prefWidth="400" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="PAN:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="panFieldEncode" promptText="Primary Account Number (13-19 digits)" prefWidth="400" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="Format:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <ComboBox fx:id="pinBlockFormatCombo" prefWidth="400" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <Button text="Encode PIN Block" onAction="#handleEncodePinBlock" 
                                    styleClass="button-primary" maxWidth="600" style="-fx-font-size: 14px;"/>
                        </VBox>
                        
                        <Label text="Decode PIN Block:" style="-fx-font-style: italic; -fx-font-size: 14px; -fx-padding: 15 0 0 0;"/>
                        <VBox spacing="12">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="PIN Block (Hex):" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="pinBlockField" promptText="16 hex chars (ISO 0/2/3) or 32 hex chars (ISO 4)" prefWidth="400" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="PAN:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="panFieldDecode" promptText="Primary Account Number" prefWidth="400" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="Format:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <ComboBox fx:id="pinBlockFormatDecodeCombo" prefWidth="400" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <Button text="Decode PIN Block" onAction="#handleDecodePinBlock" 
                                    styleClass="button-primary" maxWidth="600" style="-fx-font-size: 14px;"/>
                        </VBox>
                        
                        <TextArea fx:id="pinBlockResultArea" prefHeight="150" editable="false" wrapText="true"
                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 14px;"
                                  promptText="PIN Block encoding/decoding results will appear here..."/>
                    </VBox>
                    
                    <Separator/>
                    
                    <!-- CVV / CVV2 -->
                    <VBox spacing="15">
                        <Label text="CVV / CVV2 / iCVV / dCVV" style="-fx-font-weight: bold; -fx-font-size: 18px;"/>
                        
                        <VBox spacing="12">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="CVK A (Hex):" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="cvkAField" promptText="32 hex characters (16 bytes)" prefWidth="500" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="CVK B (Hex):" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="cvkBField" promptText="32 hex characters (16 bytes)" prefWidth="500" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="PAN:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="panFieldCvv" promptText="Primary Account Number" prefWidth="500" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="Expiry Date:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="expiryDateField" promptText="YYMM (e.g., 2512)" prefWidth="200" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="Service Code:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="serviceCodeField" promptText="3 digits (e.g., 101)" prefWidth="200" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="CVV Type:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <ComboBox fx:id="cvvTypeCombo" prefWidth="300" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15">
                                <Button text="Generate CVV" onAction="#handleGenerateCvv" 
                                        styleClass="button-primary" prefWidth="300" style="-fx-font-size: 14px;"/>
                                <Button text="Verify CVV" onAction="#handleVerifyCvv" 
                                        styleClass="button-primary" prefWidth="300" style="-fx-font-size: 14px;"/>
                            </HBox>
                        </VBox>
                        
                        <TextArea fx:id="cvvResultArea" prefHeight="130" editable="false" wrapText="true"
                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 14px;"
                                  promptText="CVV calculation results will appear here..."/>
                    </VBox>
                    
                    <Separator/>
                    
                    <!-- MAC -->
                    <VBox spacing="15">
                        <Label text="MAC (Message Authentication Code)" style="-fx-font-weight: bold; -fx-font-size: 18px;"/>
                        
                        <VBox spacing="12">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="Algorithm:" minWidth="180" style="-fx-font-size: 14px;"/>
                                <ComboBox fx:id="macAlgorithmCombo" prefWidth="400" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="MAC Key (Hex):" minWidth="180" style="-fx-font-size: 14px;"/>
                                <TextField fx:id="macKeyField" promptText="32 hex characters (16 bytes)" prefWidth="500" style="-fx-font-size: 14px;"/>
                            </HBox>
                            <VBox spacing="8">
                                <Label text="Data (Hex):" style="-fx-font-size: 14px;"/>
                                <TextArea fx:id="macDataField" prefHeight="100" wrapText="true"
                                          style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 14px;"
                                          promptText="Enter data in hexadecimal..."/>
                            </VBox>
                            <HBox spacing="15">
                                <Button text="Generate MAC" onAction="#handleGenerateMac" 
                                        styleClass="button-primary" prefWidth="300" style="-fx-font-size: 14px;"/>
                                <Button text="Verify MAC" onAction="#handleVerifyMac" 
                                        styleClass="button-primary" prefWidth="300" style="-fx-font-size: 14px;"/>
                            </HBox>
                        </VBox>
                        
                        <TextArea fx:id="macResultArea" prefHeight="130" editable="false" wrapText="true"
                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 14px;"
                                  promptText="MAC calculation results will appear here..."/>
                    </VBox>
                    
                    <Separator/>
                    
                    <!-- PIN TRANSLATION -->

                    
                </VBox>
            </ScrollPane>
            
            <!-- History Tab Content (Own Layout) -->
            <VBox fx:id="historyCenterPane" spacing="15" style="-fx-padding: 20;" visible="false" managed="false">
                
                <!-- Filters and Search -->
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Category:" style="-fx-font-size: 13px;"/>
                    <ComboBox fx:id="historyCategoryFilter" prefWidth="150" style="-fx-font-size: 13px;"/>
                    
                    <Label text="Search:" style="-fx-font-size: 13px;" HBox.hgrow="NEVER"/>
                    <TextField fx:id="historySearchField" promptText="Search operations..." 
                               prefWidth="300" style="-fx-font-size: 13px;" HBox.hgrow="ALWAYS"/>
                    
                    <Button text="🔍 Filter" onAction="#handleHistoryFilter" 
                            style="-fx-font-size: 13px;" prefWidth="90"/>
                    <Button text="↻ Refresh" onAction="#handleHistoryRefresh" 
                            style="-fx-font-size: 13px;" prefWidth="90"/>
                </HBox>
                
                <!-- History Table -->
                <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="timestampColumn" text="Timestamp" prefWidth="150"/>
                        <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120"/>
                        <TableColumn fx:id="operationColumn" text="Operation" prefWidth="250"/>
                        <TableColumn fx:id="inputColumn" text="Input" prefWidth="300"/>
                        <TableColumn fx:id="outputColumn" text="Output" prefWidth="250"/>
                    </columns>
                </TableView>
                
                <!-- Action Buttons -->
                <HBox spacing="10">
                    <Button text="📄 Export TXT" onAction="#handleExportTxt" 
                            styleClass="button-primary" prefWidth="120" style="-fx-font-size: 13px;"/>
                    <Button text="📊 Export CSV" onAction="#handleExportCsv" 
                            styleClass="button-primary" prefWidth="120" style="-fx-font-size: 13px;"/>
                    <Button text="📋 Export JSON" onAction="#handleExportJson" 
                            styleClass="button-primary" prefWidth="120" style="-fx-font-size: 13px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🗑 Clear History" onAction="#handleClearHistory" 
                            styleClass="button-danger" prefWidth="130" style="-fx-font-size: 13px;"/>
                </HBox>
                
                <Label fx:id="historyCountLabel" text="Total operations: 0" 
                       style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
            </VBox>
            
            <!-- ASN.1 Parser Content (Own Layout - Input/Output with scroll) -->
            <SplitPane fx:id="asn1CenterPane" dividerPositions="0.5" orientation="VERTICAL" visible="false" managed="false">
                
                <!-- Input Section (with scroll) -->
                <VBox spacing="5">
                    <padding>
                        <Insets top="10" right="10" bottom="5" left="10" />
                    </padding>
                    <Label text="Input Data" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                        <TextArea fx:id="asn1InputArea" wrapText="true" 
                                 promptText="Enter ASN.1 data (hex, base64, or PEM format)&#10;or click 'Load Example' in the ASN.1 tab"
                                 prefHeight="2000"
                                 style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;" />
                    </ScrollPane>
                </VBox>
                
                <!-- Output Section (with scroll) -->
                <VBox spacing="5">
                    <padding>
                        <Insets top="5" right="10" bottom="10" left="10" />
                    </padding>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="ASN.1 Structure" style="-fx-font-weight: bold; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                        <Label fx:id="asn1StatusLabel" text="Ready" 
                               style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                    </HBox>
                    <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                        <TextArea fx:id="asn1TreeArea" editable="false" wrapText="false"
                                 prefHeight="2000"
                                 style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;" />
                    </ScrollPane>
                    
                    <!-- Details at bottom -->
                    <VBox spacing="3" style="-fx-padding: 5 0 0 0;">
                        <Label text="Details:" style="-fx-font-size: 10px; -fx-font-weight: bold;" />
                        <TextArea fx:id="asn1DetailsArea" prefRowCount="3" editable="false" wrapText="true"
                                  style="-fx-font-size: 10px; -fx-background-color: #f9f9f9;"/>
                    </VBox>
                </VBox>
                
            </SplitPane>
            
        </StackPane>
    </center>
    
    <!-- Left Sidebar - Operations Panel -->
    <left>
        <TabPane fx:id="mainTabPane" side="LEFT" tabClosingPolicy="UNAVAILABLE" 
                 prefWidth="420" minWidth="380" maxWidth="600" 
                 style="-fx-tab-min-height: 40px;">
            
            <!-- Generic Tab -->
            <Tab text="Generic">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                        <Label text="HASHING" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <ComboBox fx:id="hashAlgorithmCombo" promptText="Hash Algorithm" prefWidth="260" />
                            <Button text="Calculate Hash" maxWidth="Infinity" styleClass="action-button" onAction="#handleCalculateHash" />
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="ENCODING / CONVERSION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <Label text="Select formats in toolbar above, then:" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                            <Button text="Convert Format" maxWidth="Infinity" styleClass="action-button" onAction="#handleConvert" />
                            <Separator />
                            <Button text="Generate UUID" maxWidth="Infinity" styleClass="action-button" onAction="#handleGenerateUUID" />
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="RANDOM NUMBER GENERATOR" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <HBox spacing="5" alignment="CENTER_LEFT">
                                <Label text="Bytes:" minWidth="60" />
                                <TextField fx:id="randomBytesField" promptText="Number of bytes" prefWidth="100" text="16" />
                            </HBox>
                            <ComboBox fx:id="randomFormatCombo" promptText="Output Format" prefWidth="260" />
                            <Button text="Generate Random" maxWidth="Infinity" styleClass="action-button" onAction="#handleGenerateRandom" />
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="CHECK DIGITS" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <ComboBox fx:id="checkDigitAlgorithmCombo" promptText="Algorithm" prefWidth="260" />
                            <Button text="Calculate" maxWidth="Infinity" styleClass="action-button" onAction="#handleCalculateCheckDigit" />
                            <Button text="Validate" maxWidth="Infinity" styleClass="action-button" onAction="#handleValidateCheckDigit" />
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="MODULAR ARITHMETIC CALCULATOR" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <ComboBox fx:id="modOperationCombo" promptText="Operation" prefWidth="260" />
                            <TextField fx:id="modOperandAField" promptText="Operand A (hex)" style="-fx-font-family: 'Courier New', monospace;"/>
                            <TextField fx:id="modOperandBField" promptText="Operand B (hex)" style="-fx-font-family: 'Courier New', monospace;"/>
                            <TextField fx:id="modModulusField" promptText="Modulus (hex)" style="-fx-font-family: 'Courier New', monospace;"/>
                            <Button text="Calculate" maxWidth="Infinity" styleClass="action-button" onAction="#handleModularCalculate" />
                            <Label text="Result:" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                            <TextArea fx:id="modResultArea" prefHeight="120" wrapText="true" editable="false"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                            <Label text="ℹ️  All inputs in hexadecimal. Supports very large numbers." 
                                   style="-fx-text-fill: #3498db; -fx-font-size: 10px; -fx-font-style: italic;"/>
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="FILE FORMAT CONVERTER" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <Label text="Input File:" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <HBox spacing="5">
                                <TextField fx:id="fileInputPathField" promptText="Input file path" HBox.hgrow="ALWAYS"/>
                                <Button text="Browse..." onAction="#handleBrowseInputFile" minWidth="80" />
                            </HBox>
                            
                            <Label text="Output File (optional):" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <HBox spacing="5">
                                <TextField fx:id="fileOutputPathField" promptText="Output file path (optional)" HBox.hgrow="ALWAYS"/>
                                <Button text="Browse..." onAction="#handleBrowseOutputFile" minWidth="80" />
                            </HBox>
                            
                            <Label text="Conversion:" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="From:" minWidth="50"/>
                                <ComboBox fx:id="fileInputFormatCombo" promptText="Input Format" prefWidth="150" />
                                <Label text="To:" minWidth="30"/>
                                <ComboBox fx:id="fileOutputFormatCombo" promptText="Output Format" prefWidth="150" />
                            </HBox>
                            
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Text Encoding:" minWidth="100"/>
                                <ComboBox fx:id="fileEncodingCombo" promptText="Encoding" prefWidth="200" />
                            </HBox>
                            
                            <Button text="Convert / Analyze" maxWidth="Infinity" styleClass="action-button" onAction="#handleFileConvert" />
                            <Label text="Result:" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                            <TextArea fx:id="fileResultArea" prefHeight="150" wrapText="true" editable="false"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                            <Label text="ℹ️  All conversions: Hex, Base64, Text (UTF-8, EBCDIC, etc.) - Any to Any" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-style: italic;"/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- Cipher Tab -->
            <Tab text="Cipher">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                        <Label text="SYMMETRIC ENCRYPTION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <ComboBox fx:id="symmetricAlgorithmCombo" promptText="Algorithm" prefWidth="260" />
                            <ComboBox fx:id="cipherModeCombo" promptText="Mode" prefWidth="260" />
                            <ComboBox fx:id="paddingCombo" promptText="Padding" prefWidth="260" />
                            <TextField fx:id="symmetricKeyField" promptText="Key (Hex)" />
                            <TextField fx:id="ivField" promptText="IV (Hex) - if required" />
                            
                            <HBox spacing="5">
                                <Button text="Encrypt" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" onAction="#handleSymmetricEncrypt" />
                                <Button text="Decrypt" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" onAction="#handleSymmetricDecrypt" />
                            </HBox>
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="ASYMMETRIC ENCRYPTION (RSA)" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <Label text="RSA Padding:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <ComboBox fx:id="rsaPaddingCombo" promptText="Padding Scheme" prefWidth="260" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="Load keys (PEM format):" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <Button text="Load Public Key (PEM)..." maxWidth="Infinity" styleClass="action-button" onAction="#handleLoadPublicKey" />
                            <Button text="Load Private Key (PEM)..." maxWidth="Infinity" styleClass="action-button" onAction="#handleLoadPrivateKey" />
                            <Label fx:id="asymmetricKeyStatusLabel" text="No keys loaded" style="-fx-font-size: 10px; -fx-text-fill: #666; -fx-padding: 5 0 0 0;" />
                            
                            <HBox spacing="5">
                                <Button text="Encrypt" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" onAction="#handleAsymmetricEncrypt" />
                                <Button text="Decrypt" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" onAction="#handleAsymmetricDecrypt" />
                            </HBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- Authentication Tab -->
            <Tab text="Authentication">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                        
                        <Label text="DIGITAL SIGNATURES" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <Label text="Signature Algorithm:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <ComboBox fx:id="signatureAlgorithmCombo" promptText="Select signature algorithm" prefWidth="260" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="Load keys (PEM format):" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <Button text="Load Private Key (PEM) - for signing..." maxWidth="Infinity" styleClass="action-button" onAction="#handleLoadSignPrivateKey" />
                            <Button text="Load Public Key (PEM) - for verification..." maxWidth="Infinity" styleClass="action-button" onAction="#handleLoadSignPublicKey" />
                            <Label fx:id="signatureKeyStatusLabel" text="No keys loaded" style="-fx-font-size: 10px; -fx-text-fill: #666; -fx-padding: 5 0 0 0;" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Button text="Sign" maxWidth="Infinity" styleClass="action-button" onAction="#handleSign" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="Verification:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <Label text="Signature (paste here for verification):" style="-fx-font-size: 10px;"/>
                            <TextField fx:id="signatureVerifyField" promptText="Paste signature here (format: toolbar Output Format)" />
                            
                            <Button text="Verify Signature" maxWidth="Infinity" styleClass="action-button" onAction="#handleVerify" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="ℹ️  Sign: data in Input → signature in Output" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-style: italic;"/>
                            <Label text="ℹ️  Verify: signature above, data in Input → result popup" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-style: italic;"/>
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="MESSAGE AUTHENTICATION CODES (MAC)" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <Label text="MAC Algorithm:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <ComboBox fx:id="authMacAlgorithmCombo" promptText="Select MAC algorithm" maxWidth="Infinity" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="MAC Key (Hex):" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <TextField fx:id="authMacKeyField" promptText="Enter MAC key in hexadecimal" />
                            <Label fx:id="authMacKeyInfoLabel" text="Key size depends on algorithm" 
                                   style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <VBox spacing="8" style="-fx-padding: 5 0 5 0;">
                                <Label text="Key Components (Optional - for ANSI X9.19):" 
                                       style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                <HBox spacing="10">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="K:" style="-fx-font-size: 10px; -fx-font-weight: bold;" />
                                        <TextField fx:id="authMacKeyK" promptText="First 8 bytes (hex)" />
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="K':" style="-fx-font-size: 10px; -fx-font-weight: bold;" />
                                        <TextField fx:id="authMacKeyKPrime" promptText="Second 8 bytes (hex)" />
                                    </VBox>
                                </HBox>
                                <Label text="Leave empty to use MAC Key field above. If filled, K||K' will be concatenated automatically." 
                                       style="-fx-font-size: 9px; -fx-text-fill: #666; -fx-wrap-text: true; -fx-padding: 0 0 5 0;"/>
                            </VBox>
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="Truncation:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <ComboBox fx:id="authMacTruncationCombo" prefWidth="100" />
                                <Label text="bytes (0 = full MAC)" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                            </HBox>
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Button text="Generate MAC" maxWidth="Infinity" styleClass="action-button" onAction="#handleGenerateMAC" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="Verification:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <Label text="MAC value (paste here for verification):" style="-fx-font-size: 10px;"/>
                            <TextField fx:id="authMacVerifyField" promptText="Paste MAC here (format: toolbar Output Format)" />
                            
                            <Button text="Verify MAC" maxWidth="Infinity" styleClass="action-button" onAction="#handleVerifyMAC" />
                            
                            <Separator style="-fx-padding: 5 0 5 0;" />
                            
                            <Label text="ℹ️  Generate: data in Input → MAC in Output" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-style: italic;"/>
                            <Label text="ℹ️  Verify: MAC above, data in Input → result popup" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-style: italic;"/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- Keys Tab -->
            <Tab text="Keys" closable="false">
                <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
                    <Label text="Key Operations" style="-fx-font-weight: bold; -fx-font-size: 18px;"/>
                    <Label text="All key controls and results" style="-fx-font-size: 13px;"/>
                    <Label text="are displayed in the main area →" style="-fx-font-size: 13px; -fx-text-fill: gray;"/>
                </VBox>
            </Tab>

            
            <!-- Payments Tab -->
            <Tab text="Payments" closable="false">
                <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
                    <Label text="Payment Operations" style="-fx-font-weight: bold; -fx-font-size: 18px;"/>
                    <Label text="All payment controls and results" style="-fx-font-size: 13px;"/>
                    <Label text="are displayed in the main area →" style="-fx-font-size: 13px; -fx-text-fill: gray;"/>
                </VBox>
            </Tab>
            
            <!-- EMV Tab -->
            <Tab text="EMV">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                        
                        <!-- SESSION KEY DERIVATION -->
                        <Label text="SESSION KEY DERIVATION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <TextField fx:id="imkField" promptText="Issuer Master Key (32 hex chars)" />
                            <TextField fx:id="panFieldSession" promptText="PAN (Primary Account Number)" />
                            <TextField fx:id="panSeqFieldSession" promptText="PAN Sequence (00-99)" text="00" />
                            <TextField fx:id="atcField" promptText="ATC - Application Transaction Counter (4 hex chars, optional)" />
                            <Button text="Derive Session Keys" onAction="#handleDeriveSessionKey" maxWidth="Infinity" styleClass="action-button" />
                            <TextArea fx:id="sessionKeyResultArea" prefHeight="180" editable="false" wrapText="true"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                      promptText="Session keys will appear here..."/>
                        </VBox>
                        
                        <Separator />
                        
                        <!-- ARQC GENERATION -->
                        <Label text="ARQC GENERATION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <TextField fx:id="skARQCField" promptText="Session Key (32 hex chars)" />
                            <TextField fx:id="amountField" promptText="Amount (12 hex chars, e.g., 000000012345 = 123.45)" />
                            <HBox spacing="5">
                                <TextField fx:id="currencyField" promptText="Currency (0978=EUR)" text="0978" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="countryField" promptText="Country (0724=ESP)" text="0724" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <HBox spacing="5">
                                <TextField fx:id="atcARQCField" promptText="ATC (4 hex)" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="tvrField" promptText="TVR (10 hex)" text="0000000000" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <HBox spacing="5">
                                <TextField fx:id="txDateField" promptText="Date YYMMDD (6 hex)" text="251207" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="txTypeField" promptText="Type (2 hex)" text="00" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="unField" promptText="UN (8 hex)" text="12345678" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <HBox spacing="5">
                                <Button text="Generate ARQC" onAction="#handleGenerateARQC" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" />
                                <Button text="Verify ARQC" onAction="#handleVerifyARQC" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" />
                            </HBox>
                            <TextArea fx:id="arqcResultArea" prefHeight="200" editable="false" wrapText="true"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                      promptText="ARQC results will appear here..."/>
                        </VBox>
                        
                        <Separator />
                        
                        <!-- ARPC GENERATION -->
                        <Label text="ARPC GENERATION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <TextField fx:id="skARPCField" promptText="Session Key (32 hex chars)" />
                            <TextField fx:id="arqcField" promptText="ARQC from card (16 hex chars)" />
                            <TextField fx:id="arcField" promptText="ARC - Authorization Response Code (4 hex, e.g., 3030=Approved)" />
                            <TextField fx:id="csuField" promptText="CSU - Card Status Update (8 hex, optional for Method 2)" />
                            <ComboBox fx:id="arpcMethodCombo" prefWidth="260" />
                            <Button text="Generate ARPC" onAction="#handleGenerateARPC" maxWidth="Infinity" styleClass="action-button" />
                            <TextArea fx:id="arpcResultArea" prefHeight="150" editable="false" wrapText="true"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                      promptText="ARPC will appear here..."/>
                        </VBox>
                        
                        <Separator />
                        
                        <!-- TRACK 2 OPERATIONS -->
                        <Label text="TRACK 2 DATA" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <Label text="Encode:" style="-fx-font-size: 11px; -fx-font-style: italic;" />
                            <TextField fx:id="panTrack2Field" promptText="PAN (Primary Account Number)" />
                            <HBox spacing="5">
                                <TextField fx:id="expiryTrack2Field" promptText="Expiry YYMM" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="serviceCodeFieldTrack2" promptText="Service Code (3 digits)" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <TextField fx:id="discretionaryDataField" promptText="Discretionary Data (optional)" />
                            <Button text="Encode Track 2" onAction="#handleEncodeTrack2" maxWidth="Infinity" styleClass="action-button" />
                            
                            <Label text="Decode:" style="-fx-font-size: 11px; -fx-font-style: italic; -fx-padding: 10 0 0 0;" />
                            <TextField fx:id="track2InputField" promptText="Track 2 Data (hex)" />
                            <Button text="Decode Track 2" onAction="#handleDecodeTrack2" maxWidth="Infinity" styleClass="action-button" />
                            
                            <TextArea fx:id="track2ResultArea" prefHeight="130" editable="false" wrapText="true"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                      promptText="Track 2 results will appear here..."/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- Development Tab -->
            <Tab text="Dev Tools">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                        <Label text="PADDING OPERATIONS" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <ComboBox promptText="Padding Standard" prefWidth="260" />
                            <TextField promptText="Block Size (bytes)" text="16" />
                            <HBox spacing="5">
                                <Button text="Add Padding" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" />
                                <Button text="Remove Padding" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="action-button" />
                            </HBox>
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="TRACE PARSER" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <ComboBox promptText="Source Format" prefWidth="260" />
                            <Button text="Parse Trace" maxWidth="Infinity" styleClass="action-button" />
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="STRING BUILDER" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <ComboBox promptText="Output Format" prefWidth="260" />
                            <CheckBox text="Include length information" />
                            <Button text="Convert" maxWidth="Infinity" styleClass="action-button" />
                        </VBox>
                        
                        <Separator />
                        
                        <Label text="DATA DECIMALIZATION" style="-fx-font-weight: bold;" />
                        <VBox spacing="5" styleClass="operation-group">
                            <TextField promptText="Decimalization Table" text="0123456789012345" />
                            <TextField promptText="Offset" text="0000000000000000" />
                            <ComboBox promptText="Output Type" prefWidth="260" />
                            <Button text="Decimalize" maxWidth="Infinity" styleClass="action-button" />
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- History Tab -->
            <Tab text="History">
                <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
                    <Label text="📊 Operation History" style="-fx-font-weight: bold; -fx-font-size: 18px;"/>
                    <Label text="View complete history in the" style="-fx-font-size: 13px;"/>
                    <Label text="main area →" style="-fx-font-size: 13px; -fx-text-fill: gray;"/>
                    <Separator prefWidth="200"/>
                    <Label text="All operations are automatically" style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
                    <Label text="saved and displayed" style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
                    <Label text="in a searchable table" style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
                </VBox>
            </Tab>
            
            <!-- ASN.1 Parser Tab -->
            <Tab text="ASN.1">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="12" style="-fx-padding: 15;">
                        
                        <Label text="ASN.1 PARSER" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Label text="Parse and analyze DER/BER encoded ASN.1 structures" 
                               style="-fx-font-size: 10px; -fx-text-fill: #666; -fx-wrap-text: true;"/>
                        
                        <Separator />
                        
                        <!-- Input Format -->
                        <VBox spacing="5">
                            <Label text="Input Format:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <ComboBox fx:id="asn1InputFormatCombo" maxWidth="Infinity" />
                        </VBox>
                        
                        <!-- Common Types -->
                        <VBox spacing="5">
                            <Label text="Example Types:" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                            <ComboBox fx:id="asn1TypeCombo" maxWidth="Infinity" />
                        </VBox>
                        
                        <Separator />
                        
                        <!-- Action Buttons -->
                        <VBox spacing="8">
                            <Button text="Parse ASN.1" maxWidth="Infinity" 
                                    styleClass="action-button" onAction="#handleParseASN1" />
                            <Button text="Load File..." maxWidth="Infinity" 
                                    styleClass="action-button" onAction="#handleLoadASN1File" />
                            <Button text="Load Example" maxWidth="Infinity" 
                                    styleClass="action-button" onAction="#handleLoadASN1Example" />
                            <Button text="Export Tree..." maxWidth="Infinity" 
                                    styleClass="action-button" onAction="#handleExportASN1Tree" />
                            <Button text="Clear" maxWidth="Infinity" 
                                    styleClass="action-button" onAction="#handleClearASN1" />
                        </VBox>
                        
                        <Separator />
                        
                        <!-- Info -->
                        <VBox spacing="3">
                            <Label text="ℹ️  Supported formats:" 
                                   style="-fx-text-fill: #16a085; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                            <Label text="  • X.509 Certificates" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                            <Label text="  • RSA/EC Keys" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                            <Label text="  • CSRs &amp; PKCS#7/CMS" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                            <Label text="  • Custom structures" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                        </VBox>
                        
                        <VBox spacing="3" style="-fx-padding: 10 0 0 0;">
                            <Label text="💡 Quick Start:" 
                                   style="-fx-text-fill: #3498db; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                            <Label text="  1. Select example type" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                            <Label text="  2. Click 'Load Example'" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                            <Label text="  3. Auto-parse → See tree!" 
                                   style="-fx-text-fill: #666; -fx-font-size: 9px;"/>
                        </VBox>
                        
                    </VBox>
                </ScrollPane>
            </Tab>
            
            
        </TabPane>
    </left>
    
    <!-- Status Bar -->
    <bottom>
        <HBox spacing="10" style="-fx-background-color: #f0f0f0; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="5" right="5" bottom="5" left="5" /></padding>
            <Label fx:id="statusLabel" text="Ready" HBox.hgrow="ALWAYS" />
            <Label text="Java 21 | JavaFX 21 | BouncyCastle" style="-fx-text-fill: #666;" />
        </HBox>
    </bottom>
    
</BorderPane>
