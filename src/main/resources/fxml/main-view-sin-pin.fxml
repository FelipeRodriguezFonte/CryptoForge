<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.cryptocarver.ui.MainController">
    
    <!-- Menu Bar -->
    <top>
        <VBox>
            <MenuBar styleClass="main-menu-bar">
                <Menu text="File">
                    <MenuItem text="New" accelerator="Ctrl+N" />
                    <MenuItem text="Open..." accelerator="Ctrl+O" />
                    <MenuItem text="Save..." accelerator="Ctrl+S" />
                    <SeparatorMenuItem />
                    <MenuItem text="Exit" onAction="#handleExit" accelerator="Ctrl+Q" />
                </Menu>
                
                <Menu text="Edit">
                    <MenuItem text="Clear Input" onAction="#handleClearInput" accelerator="Ctrl+Shift+I" />
                    <MenuItem text="Clear Output" onAction="#handleClearOutput" accelerator="Ctrl+Shift+O" />
                    <MenuItem text="Copy Output" onAction="#handleCopyOutput" accelerator="Ctrl+C" />
                </Menu>
                
                <Menu text="View">
                    <Menu text="Theme">
                        <RadioMenuItem fx:id="themeLightItem" text="Light (Default)" selected="true" onAction="#handleThemeLight"/>
                        <RadioMenuItem fx:id="themeDarkItem" text="Dark" onAction="#handleThemeDark"/>
                        <RadioMenuItem fx:id="themeHighContrastItem" text="High Contrast" onAction="#handleThemeHighContrast"/>
                        <RadioMenuItem fx:id="themeSolarizedItem" text="Solarized Dark" onAction="#handleThemeSolarized"/>
                        <RadioMenuItem fx:id="themeDraculaItem" text="Dracula" onAction="#handleThemeDracula"/>
                    </Menu>
                    <Menu text="Font Size">
                        <RadioMenuItem fx:id="fontSmallItem" text="Small (11px)" onAction="#handleFontSmall"/>
                        <RadioMenuItem fx:id="fontMediumItem" text="Medium (13px)" selected="true" onAction="#handleFontMedium"/>
                        <RadioMenuItem fx:id="fontLargeItem" text="Large (15px)" onAction="#handleFontLarge"/>
                        <RadioMenuItem fx:id="fontExtraLargeItem" text="Extra Large (18px)" onAction="#handleFontExtraLarge"/>
                    </Menu>
                    <SeparatorMenuItem/>
                    <MenuItem text="Reset to Defaults" onAction="#handleResetView"/>
                </Menu>
                
                <Menu text="Tools">
                    <MenuItem text="KeyStore Manager..." />
                    <MenuItem text="Import Key..." />
                    <MenuItem text="Export Key..." />
                    <SeparatorMenuItem />
                    <MenuItem text="Preferences..." />
                </Menu>
                
                <Menu text="Help">
                    <MenuItem text="Documentation" />
                    <MenuItem text="Cipher Reference" />
                    <SeparatorMenuItem />
                    <MenuItem text="About" onAction="#handleAbout" />
                </Menu>
            </MenuBar>
            
            <!-- Toolbar -->
            <ToolBar>
                <Button text="Clear" onAction="#handleClearInput" />
                <Separator orientation="VERTICAL" />
                <Label text="Input Format:" />
                <ComboBox fx:id="inputFormatCombo" prefWidth="120" />
                <Separator orientation="VERTICAL" />
                <Label text="Output Format:" />
                <ComboBox fx:id="outputFormatCombo" prefWidth="120" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Copy Output" onAction="#handleCopyOutput" />
            </ToolBar>
        </VBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <StackPane fx:id="centerStack">
            
            <!-- Generic/Cipher Content (Input/Output) -->
            <SplitPane fx:id="genericCenterPane" dividerPositions="0.7" orientation="VERTICAL">
                
                <!-- Input Section -->
                <VBox spacing="5">
                    <padding>
                        <Insets top="10" right="10" bottom="5" left="10" />
                    </padding>
                    <Label text="Input Data" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <TextArea fx:id="inputArea" VBox.vgrow="ALWAYS" wrapText="true" 
                             style="-fx-font-family: 'Courier New', monospace;" />
                </VBox>
                
                <!-- Output Section -->
                <VBox spacing="5">
                    <padding>
                        <Insets top="5" right="10" bottom="10" left="10" />
                    </padding>
                    <Label text="Output" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <TextArea fx:id="outputArea" VBox.vgrow="ALWAYS" wrapText="true" 
                             editable="false" style="-fx-font-family: 'Courier New', monospace;" />
                </VBox>
                
            </SplitPane>
            
            <!-- Keys Tab Content (Own Layout) -->
            <!-- Keys Tab Content (TabPane for different key types) -->
            <TabPane fx:id="keysCenterPane" tabClosingPolicy="UNAVAILABLE" visible="false" managed="false">
                
                <!-- Symmetric Keys Tab -->
                <Tab text="Symmetric Keys" closable="false">
                    <HBox spacing="0">
                        <!-- LEFT PANEL: Controls (35%) with scroll -->
                        <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" 
                                    prefWidth="500" minWidth="450" HBox.hgrow="NEVER">
                            <VBox spacing="15" style="-fx-padding: 20;">
                                
                                <!-- KEY GENERATION -->
                                <Label text="KEY GENERATION" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                                <VBox spacing="10">
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Type:" minWidth="80" style="-fx-font-size: 13px;"/>
                                        <ComboBox fx:id="keyTypeCombo" prefWidth="200" style="-fx-font-size: 13px;"/>
                                    </HBox>
                                    <CheckBox fx:id="forceOddParityCheck" text="Force Odd Parity (for DES/3DES keys)" 
                                              style="-fx-font-size: 12px;" selected="true"/>
                                    <Button text="Generate Key" onAction="#handleGenerateKey" styleClass="button-primary" 
                                            maxWidth="Infinity" style="-fx-font-size: 13px;"/>
                                    <TextArea fx:id="generatedKeyField" prefHeight="70" editable="false" wrapText="true"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 12px;"
                                              promptText="Generated key will appear here..."/>
                                </VBox>

                                <Separator/>

                                <!-- KEY VALIDATION -->
                                <Label text="VALIDATION &amp; KCV" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                                <VBox spacing="10">
                                    <Label text="Key (Hex):" style="-fx-font-size: 13px;"/>
                                    <TextArea fx:id="keyInputField" prefHeight="70" wrapText="true"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 12px;"
                                              promptText="Enter key in hexadecimal..."/>
                                    <Button text="Validate &amp; Calculate KCVs" onAction="#handleValidateKey" 
                                            styleClass="button-primary" maxWidth="Infinity" style="-fx-font-size: 13px;"/>
                                </VBox>

                                <Separator/>

                                <!-- KEY SHARING -->
                                <Label text="KEY SHARING" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                                
                                <Label text="Split Key:" style="-fx-font-style: italic; -fx-font-size: 13px;"/>
                                <VBox spacing="10">
                                    <TextArea fx:id="keyToSplitField" prefHeight="70" wrapText="true"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 12px;"
                                              promptText="Enter key to split..."/>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Parts:" minWidth="50" style="-fx-font-size: 13px;"/>
                                        <ComboBox fx:id="numComponentsCombo" prefWidth="80" style="-fx-font-size: 13px;"/>
                                        <Button text="Split" onAction="#handleSplitKey" styleClass="button-primary" 
                                                HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-size: 13px;"/>
                                    </HBox>
                                </VBox>

                                <Label text="Combine:" style="-fx-font-style: italic; -fx-font-size: 13px; -fx-padding: 10 0 0 0;"/>
                                <VBox spacing="8">
                                    <TextArea fx:id="component1Field" prefHeight="50" wrapText="true" promptText="Component 1"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                                    <TextArea fx:id="component2Field" prefHeight="50" wrapText="true" promptText="Component 2"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                                    <TextArea fx:id="component3Field" prefHeight="50" wrapText="true" promptText="Component 3 (optional)"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                                    <TextArea fx:id="component4Field" prefHeight="50" wrapText="true" promptText="Component 4 (optional)"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                                    <TextArea fx:id="component5Field" prefHeight="50" wrapText="true" promptText="Component 5 (optional)"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                                    <Button text="Combine Components" onAction="#handleCombineComponents" 
                                            styleClass="button-primary" maxWidth="Infinity" style="-fx-font-size: 13px;"/>
                                </VBox>
                                
                                <Separator/>
                                
                                <!-- KEY DERIVATION -->
                                <Label text="KEY DERIVATION" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                                <VBox spacing="10">
                                    <Label text="Algorithm:" style="-fx-font-size: 13px;"/>
                                    <ComboBox fx:id="kdfAlgorithmCombo" prefWidth="260" style="-fx-font-size: 13px;"/>
                                    
                                    <Label text="Input Key Material:" style="-fx-font-size: 13px;"/>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Format:" minWidth="60" style="-fx-font-size: 11px;"/>
                                        <ComboBox fx:id="kdfInputFormatCombo" prefWidth="100" style="-fx-font-size: 11px;"/>
                                    </HBox>
                                    <TextArea fx:id="kdfInputField" prefHeight="60" wrapText="true"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              promptText="Enter key material..."/>
                                    
                                    <Label text="Salt (optional):" style="-fx-font-size: 13px;"/>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Format:" minWidth="60" style="-fx-font-size: 11px;"/>
                                        <ComboBox fx:id="kdfSaltFormatCombo" prefWidth="100" style="-fx-font-size: 11px;"/>
                                    </HBox>
                                    <TextField fx:id="kdfSaltField" promptText="Leave empty for no salt (HKDF will use zeros)" 
                                               style="-fx-font-size: 11px;"/>
                                    
                                    <Label text="Info/Context (optional):" style="-fx-font-size: 13px;"/>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Format:" minWidth="60" style="-fx-font-size: 11px;"/>
                                        <ComboBox fx:id="kdfInfoFormatCombo" prefWidth="100" style="-fx-font-size: 11px;"/>
                                    </HBox>
                                    <TextField fx:id="kdfInfoField" promptText="Optional context info (HKDF only)" 
                                               style="-fx-font-size: 11px;"/>
                                    
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Iterations:" minWidth="100" style="-fx-font-size: 13px;"/>
                                        <TextField fx:id="kdfIterationsField" prefWidth="120" text="10000" 
                                                   style="-fx-font-size: 11px;"/>
                                    </HBox>
                                    
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Output Length:" minWidth="100" style="-fx-font-size: 13px;"/>
                                        <TextField fx:id="kdfOutputLengthField" prefWidth="120" text="32" 
                                                   style="-fx-font-size: 11px;"/>
                                        <Label text="bytes" style="-fx-font-size: 11px;"/>
                                    </HBox>
                                    
                                    <Button text="Derive Key" onAction="#handleDeriveKey" 
                                            styleClass="button-primary" maxWidth="Infinity" style="-fx-font-size: 13px;"/>
                                </VBox>
                            </VBox>
                        </ScrollPane>

                        <!-- DIVIDER -->
                        <Separator orientation="VERTICAL"/>

                        <!-- RIGHT PANEL: Results (65%) -->
                        <ScrollPane fitToWidth="true" fitToHeight="true" vbarPolicy="AS_NEEDED" HBox.hgrow="ALWAYS">
                            <VBox spacing="20" style="-fx-padding: 25;">
                                
                                <Label text="VALIDATION RESULTS" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                                <TextArea fx:id="validationResultArea" prefHeight="450" wrapText="true" editable="false" 
                                          VBox.vgrow="ALWAYS"
                                          style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 13px;"
                                          promptText="Validation results and KCV values will appear here..."/>

                                <Separator/>

                                <Label text="KEY COMPONENTS" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                                <TextArea fx:id="componentResultsArea" prefHeight="350" wrapText="true" editable="false" 
                                          VBox.vgrow="ALWAYS"
                                          style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 13px;"
                                          promptText="Key components or combined key will appear here..."/>
                            </VBox>
                        </ScrollPane>
                    </HBox>
                </Tab>
                
                <!-- RSA Tab -->
                <Tab text="RSA" closable="false">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="RSA Key Generation" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Key Size:"/>
                                <ComboBox fx:id="rsaKeySizeCombo" prefWidth="120"/>
                                <Button text="Generate RSA Key Pair" onAction="#handleGenerateRSA" 
                                        style="-fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white;"/>
                            </HBox>
                            
                            <Separator/>
                            
                            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS" orientation="HORIZONTAL">
                                <VBox spacing="5">
                                    <Label text="Public Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="rsaPublicKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Private Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="rsaPrivateKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                            </SplitPane>
                            
                            <Label text="⚠️  RSA keys > 4096 bits may take several seconds to generate" 
                                   style="-fx-text-fill: #e67e22; -fx-font-style: italic;"/>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <!-- DSA Tab -->
                <Tab text="DSA" closable="false">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="DSA Key Generation" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Key Size (L/N):"/>
                                <ComboBox fx:id="dsaKeySizeCombo" prefWidth="120"/>
                                <Button text="Generate DSA Key Pair" onAction="#handleGenerateDSA"
                                        style="-fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white;"/>
                            </HBox>
                            
                            <Separator/>
                            
                            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS" orientation="HORIZONTAL">
                                <VBox spacing="5">
                                    <Label text="Public Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="dsaPublicKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Private Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="dsaPrivateKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                            </SplitPane>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <!-- ECDSA F(p) Tab -->
                <Tab text="ECDSA F(p)" closable="false">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="ECDSA F(p) - Elliptic Curve over Prime Field" 
                                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Named Curve:"/>
                                <ComboBox fx:id="ecdsaFpCurveCombo" prefWidth="150"/>
                                <Button text="Generate ECDSA F(p) Key Pair" onAction="#handleGenerateECDSAFp"
                                        style="-fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white;"/>
                            </HBox>
                            
                            <Separator/>
                            
                            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS" orientation="HORIZONTAL">
                                <VBox spacing="5">
                                    <Label text="Public Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="ecdsaFpPublicKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Private Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="ecdsaFpPrivateKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                            </SplitPane>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <!-- Ed25519 Tab -->
                <Tab text="Ed25519" closable="false">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="Ed25519 - Modern Elliptic Curve Signature" 
                                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Ed25519 (255-bit curve, fast signatures)"/>
                                <Button text="Generate Ed25519 Key Pair" onAction="#handleGenerateEd25519"
                                        style="-fx-font-weight: bold; -fx-background-color: #9b59b6; -fx-text-fill: white;"/>
                            </HBox>
                            
                            <Separator/>
                            
                            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS" orientation="HORIZONTAL">
                                <VBox spacing="5">
                                    <Label text="Public Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="ed25519PublicKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Private Key" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="ed25519PrivateKeyArea" wrapText="true" editable="false"
                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                              VBox.vgrow="ALWAYS" prefHeight="500"/>
                                </VBox>
                            </SplitPane>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                
                <!-- Certificates Tab -->
                <Tab text="Certificates" closable="false">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="X.509 Self-Signed Certificate Generator" 
                                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            
                            <GridPane hgap="10" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="30"/>
                                    <ColumnConstraints percentWidth="70"/>
                                </columnConstraints>
                                
                                <Label text="Common Name (CN):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="certCNField" promptText="localhost" 
                                          GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                
                                <Label text="Organization (O):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <TextField fx:id="certOrgField" promptText="Crypto Org" 
                                          GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                
                                <Label text="Organizational Unit (OU):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <TextField fx:id="certOUField" promptText="Cybersecurity" 
                                          GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                
                                <Label text="Locality (L):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <TextField fx:id="certLocalityField" promptText="Madrid" 
                                          GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                
                                <Label text="State (ST):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                <TextField fx:id="certStateField" promptText="Madrid" 
                                          GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                
                                <Label text="Country (C):" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                <TextField fx:id="certCountryField" promptText="ES" maxWidth="60"
                                          GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                                
                                <Separator GridPane.rowIndex="6" GridPane.columnSpan="2"/>
                                
                                <Label text="Validity (days):" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                                <TextField fx:id="certValidityField" text="365" maxWidth="100"
                                          GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                                
                                <Label text="Key Type:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="certKeyTypeCombo" prefWidth="150"
                                         GridPane.rowIndex="8" GridPane.columnIndex="1"/>
                                
                                <Label text="Signature Algorithm:" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="certSignAlgoCombo" prefWidth="200"
                                         GridPane.rowIndex="9" GridPane.columnIndex="1"/>
                            </GridPane>
                            
                            <Button text="Generate Self-Signed Certificate" onAction="#handleGenerateCertificate"
                                    style="-fx-font-weight: bold; -fx-background-color: #e74c3c; -fx-text-fill: white;"
                                    prefWidth="300"/>
                            
                            <Separator/>
                            
                            <Label text="Certificate Output (PEM + Private Key)" style="-fx-font-weight: bold;"/>
                            <TextArea fx:id="certOutputArea" wrapText="true" editable="false"
                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"
                                      VBox.vgrow="ALWAYS" prefHeight="400"/>
                                      
                            <Label text="⚠️  WARNING: Self-signed certificates are NOT suitable for production use" 
                                   style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <!-- TR-31 Key Block Tab -->
                <Tab text="TR-31 Key Block" closable="false">
                    <HBox spacing="0">
                        <!-- LEFT PANEL: Controls -->
                        <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" 
                                    prefWidth="500" minWidth="450" HBox.hgrow="NEVER">
                            <VBox spacing="20" style="-fx-padding: 20;">
                                
                                <!-- TR-31 EXPORT (WRAP) -->
                                <Label text="TR-31 EXPORT (WRAP KEY)" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                                <VBox spacing="10">
                                    <Label text="KBPK (Key Block Protection Key):" style="-fx-font-size: 13px;"/>
                                    <TextField fx:id="tr31KbpkExportField" promptText="KBPK in hex (16 or 32 bytes)"
                                               style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 12px;"/>
                                    
                                    <Label text="Key to Wrap:" style="-fx-font-size: 13px;"/>
                                    <TextField fx:id="tr31KeyToWrapField" promptText="Key in hex"
                                               style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 12px;"/>
                                    
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Version ID:" minWidth="100" style="-fx-font-size: 13px;"/>
                                        <ComboBox fx:id="tr31VersionCombo" prefWidth="200" style="-fx-font-size: 13px;"/>
                                    </HBox>
                                    
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Key Usage:" minWidth="100" style="-fx-font-size: 13px;"/>
                                        <ComboBox fx:id="tr31UsageCombo" prefWidth="200" style="-fx-font-size: 13px;"/>
                                    </HBox>
                                    
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Algorithm:" minWidth="100" style="-fx-font-size: 13px;"/>
                                        <ComboBox fx:id="tr31AlgorithmCombo" prefWidth="200" style="-fx-font-size: 13px;"/>
                                    </HBox>
                                    
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Mode of Use:" minWidth="100" style="-fx-font-size: 13px;"/>
                                        <ComboBox fx:id="tr31ModeCombo" prefWidth="200" style="-fx-font-size: 13px;"/>
                                    </HBox>
                                    
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="Exportability:" minWidth="100" style="-fx-font-size: 13px;"/>
                                        <ComboBox fx:id="tr31ExportabilityCombo" prefWidth="200" style="-fx-font-size: 13px;"/>
