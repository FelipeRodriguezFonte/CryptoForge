                                            <Label text="ARQC (from card):" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="arqcField" promptText="8 bytes ARQC" 
                                                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>
                                            
                                            <Label text="Response Code (ARC):" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="arcField" promptText="e.g. 3030 (Approved)" 
                                                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>
                                            
                                            <Label text="CSU (Optional, for Method 2):" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="csuField" promptText="4 bytes Card Status Update" 
                                                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                            <Label text="Prop. Auth. Data (Optional):" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="propAuthDataField" promptText="Proprietary Authentication Data (Hex)" 
                                                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>
                                            
                                            <Label text="Method:" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="arpcMethodCombo" prefWidth="250" style="-fx-font-size: 11px;"/>
                                            
                                            <HBox spacing="10">
                                                <Button text="Generate ARPC" onAction="#handleGenerateARPC" 
                                                        styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                                <Button text="Verify ARQC (Sim)" onAction="#handleVerifyARQC" 
                                                        styleClass="secondary-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                            </HBox>
                                            
                                            <TextArea fx:id="arpcResultArea" prefHeight="80" editable="false" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;" managed="false" visible="false"/>
                                        </VBox>
                                    </TitledPane>
                                    
                                    <!-- TRACK 2 DATA -->
                                    <TitledPane text="🎞 Track 2 Data">
                                        <VBox spacing="8" style="-fx-padding: 10;">
                                            <TabPane tabClosingPolicy="UNAVAILABLE">
                                                <Tab text="Encode">
                                                    <VBox spacing="8" style="-fx-padding: 8;">
                                                        <Label text="PAN:" style="-fx-font-size: 11px;"/>
                                                        <TextField fx:id="panTrack2Field" promptText="Primary Account Number" style="-fx-font-size: 11px;"/>
                                                        
                                                        <GridPane hgap="8" vgap="4">
                                                            <columnConstraints>
                                                                <ColumnConstraints percentWidth="50"/>
                                                                <ColumnConstraints percentWidth="50"/>
                                                            </columnConstraints>
                                                            <Label text="Expiry (YYMM):" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                            <TextField fx:id="expiryTrack2Field" promptText="2512" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                            
                                                            <Label text="Service Code:" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                                                            <TextField fx:id="serviceCodeFieldTrack2" promptText="201" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                                                        </GridPane>
                                                        
                                                        <Label text="Discretionary Data:" style="-fx-font-size: 11px;"/>
                                                        <TextField fx:id="discretionaryDataField" promptText="Optional" style="-fx-font-size: 11px;"/>
                                                        
                                                        <Button text="Encode Track 2" onAction="#handleEncodeTrack2" 
                                                                styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                                    </VBox>
                                                </Tab>
                                                <Tab text="Decode">
                                                    <VBox spacing="8" style="-fx-padding: 8;">
                                                        <Label text="Track 2 Hex / String:" style="-fx-font-size: 11px;"/>
                                                        <TextField fx:id="track2InputField" promptText="Paste Track 2 data" style="-fx-font-size: 11px;"/>
                                                        
                                                        <Button text="Decode Track 2" onAction="#handleDecodeTrack2" 
                                                                styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                                    </VBox>
                                                </Tab>
                                            </TabPane>
                                            
                                            <TextArea fx:id="track2ResultArea" prefHeight="100" editable="false" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;" managed="false" visible="false"/>
                                        </VBox>
                                    </TitledPane>
                                </panes>
                            </Accordion>
                        </VBox>
                        
                        <!-- Generic Utilities Container -->
                        <!-- GENERIC CONTENT (Hashing, Encoding, etc) -->
                <Accordion fx:id="genericContainer" managed="false" visible="false">
                        <panes>
                            <!-- HASHING -->
                            <TitledPane text="🔐 Hashing" expanded="true">
                                <VBox spacing="6" style="-fx-padding: 8;">
                                    <Label text="Algorithm:" style="-fx-font-size: 11px;"/>
                                    <ComboBox fx:id="hashAlgorithmCombo" prefWidth="200" style="-fx-font-size: 11px;"/>
                                    
                                    <Label text="Input:" style="-fx-font-size: 11px;"/>
                                    <TextArea fx:id="hashInputArea" prefRowCount="3" wrapText="true" style="-fx-font-size: 11px;"/>
                                    
                                    <Label text="Output:" style="-fx-font-size: 11px;"/>
                                    <TextArea fx:id="hashOutputArea" prefRowCount="2" editable="false" wrapText="true" style="-fx-font-size: 11px; -fx-font-family: monospace;"/>
                                    
                                    <Button text="Calculate Hash" onAction="#handleCalculateHash" 
                                            styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>
                                </VBox>
                            </TitledPane>

                            <!-- ENCODING/CONVERSION -->
                            <TitledPane text="🔄 File Conversion" expanded="false">
                                <VBox spacing="6" style="-fx-padding: 8;">
                                    <GridPane hgap="5" vgap="5">
                                        <Label text="Source:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-size: 10px;"/>
                                        <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0" HBox.hgrow="ALWAYS">
                                            <TextField fx:id="fileInputPathField" promptText="Input File Path" HBox.hgrow="ALWAYS" style="-fx-font-size: 10px;"/>
                                            <Button text="..." onAction="#handleBrowseInputFile" style="-fx-font-size: 10px; -fx-min-width: 25px;"/>
                                        </HBox>
                                        
                                        <Label text="Target:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-size: 10px;"/>
                                        <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1" HBox.hgrow="ALWAYS">
                                            <TextField fx:id="fileOutputPathField" promptText="Output File Path" HBox.hgrow="ALWAYS" style="-fx-font-size: 10px;"/>
                                            <Button text="..." onAction="#handleBrowseOutputFile" style="-fx-font-size: 10px; -fx-min-width: 25px;"/>
                                        </HBox>
                                        
                                        <Label text="Format:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-size: 10px;"/>
                                        <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                            <ComboBox fx:id="fileInputFormatCombo" promptText="In" prefWidth="80" style="-fx-font-size: 10px;"/>
                                            <Label text="->" style="-fx-font-size: 10px;"/>
                                            <ComboBox fx:id="fileOutputFormatCombo" promptText="Out" prefWidth="80" style="-fx-font-size: 10px;"/>
                                        </HBox>
                                        
                                        <Label text="Encoding:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-size: 10px;"/>
                                        <ComboBox fx:id="fileEncodingCombo" prefWidth="120" 
                                                  GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-font-size: 10px;"/>
                                    </GridPane>
                                    
                                    <TextArea fx:id="fileResultArea" prefRowCount="2" editable="false" 
                                              wrapText="true" style="-fx-font-family: monospace; -fx-font-size: 10px;"/>
                                    
                                    <Button text="Convert File" onAction="#handleConvertFile"
                                            maxWidth="180" styleClass="action-button" style="-fx-font-size: 11px;"/>
                                </VBox>
                            </TitledPane>

                            <!-- MANUAL CONVERSION (NEW) -->
                            <TitledPane text="🔤 Manual Conversion" expanded="false">
                                <VBox spacing="6" style="-fx-padding: 8;">

                                     <Label text="Input:" style="-fx-font-size: 11px;"/>
                                     <TextArea fx:id="manualInputArea" prefRowCount="3" wrapText="true" style="-fx-font-size: 11px;"/>
                                     
                                     <Label text="Output:" style="-fx-font-size: 11px;"/>
                                     <TextArea fx:id="manualOutputArea" prefRowCount="3" editable="false" wrapText="true" style="-fx-font-size: 11px; -fx-font-family: monospace;"/>
                                     
                                     <Button text="Convert Data" onAction="#handleManualConvert"
                                            maxWidth="180" styleClass="action-button" style="-fx-font-size: 11px;"/>
                                </VBox>
                            </TitledPane>

                            <!-- UUID GENERATOR -->
                            <TitledPane text="🆔 UUID Generator" expanded="false">
                                <VBox spacing="6" style="-fx-padding: 8;">
                                    <Label text="Generate random UUID (v4):" style="-fx-font-size: 11px;"/>
                                    <TextField fx:id="uuidOutputField" editable="false" style="-fx-font-size: 11px;"/>
                                    <Button text="Generate UUID" onAction="#handleGenerateUUID"
                                            maxWidth="180" styleClass="action-button" style="-fx-font-size: 11px;"/>
                                </VBox>
                            </TitledPane>

                            <!-- RANDOM NUMBER GENERATOR -->
                            <TitledPane text="🎲 Random Generator" expanded="false">
                                <VBox spacing="6" style="-fx-padding: 8;">
                                    <GridPane hgap="5" vgap="5">
                                        <Label text="Bytes:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-size: 11px;"/>
                                        <TextField fx:id="randomBytesField" text="16" prefWidth="80" 
                                                   GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-size: 11px;"/>
                                        
                                        <Label text="Format:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-size: 11px;"/>
                                        <ComboBox fx:id="randomFormatCombo" prefWidth="150" 
                                                  GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-size: 11px;"/>
                                    </GridPane>
                                    
                                    <Label text="Output:" style="-fx-font-size: 11px;"/>
                                    <TextArea fx:id="randomOutputArea" prefRowCount="3" editable="false" wrapText="true" style="-fx-font-size: 11px; -fx-font-family: monospace;"/>

                                    <Button text="Generate Random" onAction="#handleGenerateRandom" 
                                            styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>
                                </VBox>
                            </TitledPane>
                            
                            <!-- CHECK DIGITS -->
                            <TitledPane text="✅ Check Digits" expanded="false">
                                <VBox spacing="6" style="-fx-padding: 8;">
                                    <Label text="Algorithm:" style="-fx-font-size: 11px;"/>
                                    <ComboBox fx:id="checkDigitAlgorithmCombo" prefWidth="200" style="-fx-font-size: 11px;"/>
                                    
                                    <Label text="Input:" style="-fx-font-size: 11px;"/>
                                    <TextField fx:id="checkDigitInput" promptText="Enter number" style="-fx-font-size: 11px;"/>
                                    
                                    <Label text="Output / Validation:" style="-fx-font-size: 11px;"/>
                                    <TextField fx:id="checkDigitOutput" editable="false" style="-fx-font-size: 11px;"/>
                                    
                                    <HBox spacing="10">
                                        <Button text="Calculate" onAction="#handleCalculateCheckDigit" 
                                                styleClass="action-button" style="-fx-font-size: 11px;"/>
                                        <Button text="Validate" onAction="#handleValidateCheckDigit" 
                                                styleClass="secondary-button" style="-fx-font-size: 11px;"/>
                                    </HBox>
                                </VBox>
                            </TitledPane>
                            
                            <!-- MODULAR ARITHMETIC -->
                            <TitledPane text="🔢 Modular Arithmetic" expanded="false">
                                <VBox spacing="6" style="-fx-padding: 8;">
                                    <Label text="Operation:" style="-fx-font-size: 11px;"/>
                                    <ComboBox fx:id="modOperationCombo" prefWidth="200" style="-fx-font-size: 11px;"/>
                                    
                                    <Label text="Operand A (Hex):" style="-fx-font-size: 11px;"/>
                                    <TextField fx:id="modOperandAField" style="-fx-font-size: 11px;"/>
                                    
                                    <Label text="Operand B (Hex):" style="-fx-font-size: 11px;"/>
                                    <TextField fx:id="modOperandBField" style="-fx-font-size: 11px;"/>
                                    
                                    <Label text="Modulus (Hex):" style="-fx-font-size: 11px;"/>
                                    <TextField fx:id="modModulusField" style="-fx-font-size: 11px;"/>
                                    
                                    <Button text="Calculate" onAction="#handleModularCalculate"
                                            maxWidth="180" styleClass="action-button" style="-fx-font-size: 11px;"/>
                                            
                                    <Label text="Result:" style="-fx-font-size: 11px;"/>
                                    <TextArea fx:id="modResultArea" prefRowCount="2" editable="false" 
                                              wrapText="true" style="-fx-font-family: monospace; -fx-font-size: 11px;"/>
                                </VBox>
                            </TitledPane>
                        </panes>
                    </Accordion>
                        
                    </VBox>
                </ScrollPane>
            </VBox>
            
            <!-- Inspector Panel (right, collapsible) -->
            <VBox fx:id="inspectorPanel" minWidth="280" maxWidth="280" styleClass="inspector-panel">
                
                <!-- Inspector Header -->
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="inspector-header-bar">
                    <Label text="Inspector" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#handleToggleInspector" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>
                </HBox>
                
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox spacing="0">
                        
                        <!-- Input/Output Section -->
                        <VBox spacing="8" style="-fx-padding: 12;">
                            <GridPane hgap="10" vgap="5">
                                <Label text="Input Bytes:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="inspector-label-small"/>
                                <Label fx:id="inputBytesLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="inspector-value"/>
                                
                                <Label text="Output Bytes:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="inspector-label-small"/>
                                <Label fx:id="outputBytesLabel" text="32" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="inspector-value"/>
                                
                                <columnConstraints>
                                    <ColumnConstraints minWidth="100"/>
                                    <ColumnConstraints hgrow="ALWAYS" halignment="RIGHT"/>
                                </columnConstraints>
                            </GridPane>
                            
                            <Separator styleClass="separator-horizontal"/>
                            
                            <VBox spacing="4">
                                <Label text="Algorithm:" styleClass="inspector-label-small"/>
                                <Label fx:id="operationLabel" text="HKDF-SHA256" style="-fx-font-weight: bold;"/>
                            </VBox>
                            
                             <Separator styleClass="separator-horizontal"/>
                             
                             <!-- Dynamic Details -->
                             <VBox fx:id="inspectorDetailsContainer" spacing="4">
                                 <!-- Details will be added here programmatically -->
                             </VBox>
                        </VBox>
                        
                        <!-- Security Tips Section -->
                        <HBox styleClass="inspector-section-header">
                            <Label text="Security Tips" styleClass="inspector-section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="&lt;" style="-fx-text-fill: white; -fx-font-size: 10px;"/>
                        </HBox>
                        
                        <VBox style="-fx-padding: 12;">
                            <VBox styleClass="warning-box" spacing="5">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="⚠️" style="-fx-font-size: 16px;"/>
                                    <Label text="Warning" styleClass="warning-title"/>
                                </HBox>
                                <Label fx:id="securityTipLabel" text="No salt provided, HKDF is less secure! Consider using a random salt." 
                                       wrapText="true" styleClass="warning-text"/>
                            </VBox>
                        </VBox>
                        
                        <!-- History Section -->
                        <HBox styleClass="inspector-section-header">
                            <Label text="History" styleClass="inspector-section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Export" onAction="#handleExportHistory" style="-fx-font-size: 10px; -fx-padding: 2 6; -fx-background-color: transparent; -fx-text-fill: #81c784; -fx-cursor: hand;"/>
                            <Button text="Clear" onAction="#handleClearHistory" style="-fx-font-size: 10px; -fx-padding: 2 6; -fx-background-color: transparent; -fx-text-fill: #90caf9; -fx-cursor: hand;"/>
                        </HBox>
                        
                        <VBox fx:id="historyContainer" spacing="4" style="-fx-padding: 8;">
                            <!-- Example Items -->
                            <HBox styleClass="history-item" spacing="8" alignment="CENTER_LEFT">
                                <Label text="🕒"/>
                                <VBox>
                                    <Label text="HKDF SHA256 32B" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Rerun" style="-fx-font-size: 10px; -fx-padding: 2 6;"/>
                            </HBox>
                            
                            <HBox styleClass="history-item" spacing="8" alignment="CENTER_LEFT">
                                <Label text="🕒"/>
                                <VBox>
                                    <Label text="AES-GCM Encrypt" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Rerun" style="-fx-font-size: 10px; -fx-padding: 2 6;"/>
                            </HBox>
                        </VBox>
                        
                    </VBox>
                </ScrollPane>
            </VBox>
            
        </HBox>
    </center>
    
    <!-- Status Bar -->
    <bottom>
        <HBox styleClass="status-bar" spacing="10">
            <Label fx:id="statusLabel" text="Ready" styleClass="status-label-main"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Java 21 | JavaFX 21 | BouncyCastle" styleClass="status-label-info"/>
        </HBox>
    </bottom>
    
</BorderPane>
